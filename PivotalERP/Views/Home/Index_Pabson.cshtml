                    <div class="modal-header p-2">
                        <h6 class="modal-title text-success"><b>KYC Form</b> </h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body p-2">
                        <div id="customer-form">
                            <div class="timeline registration-form mt-2">
                                <div class="time-label">
                                    <span style=" border: 1px solid #ececec;">Customer Information</span>
                                </div>
                                <!-- timeline item -->
                                <div>
                                    <div class="timeline-item">
                                        <div class="row">
                                            <div class="col-md-10">
                                                <div class="row">
                                                    <div class="col-md-2">
                                                        <div class="form-group">
                                                            <label>Customer Code</label>
                                                            <input type="text" class="form-control form-control-sm " readonly ng-model="KYC.CompanyCode" disabled>
                                                        </div>
                                                    </div>


                                                    <div class="col-md-10">
                                                        <div class="form-group">
                                                            <label>Company Name</label>
                                                            <input type="text" class="form-control form-control-sm " readonly ng-model="KYC.CompanyName" disabled>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label>Billing Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="KYC.BillingName">
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Company Regd. No.</label>
                                                            <input type="text" ng-model="KYC.CompanyRegdNo" class="form-control form-control-sm" placeholder="" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Company Pan No.</label>
                                                            <input type="text" ng-model="KYC.CompanyPanNo" class="form-control form-control-sm" placeholder="" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Company Contact No.</label>
                                                            <input type="text" ng-model="KYC.CompanyContactNo" class="form-control form-control-sm" placeholder="" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Company Email</label>
                                                            <input type="text" ng-model="KYC.CompanyEmailId" class="form-control form-control-sm" placeholder="" />
                                                        </div>
                                                    </div>



                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Province/State</label>
                                                            <select class="form-control form-control-sm select2" id="cboProvince"
                                                                    style="width: 100%;" ng-model="KYC.ProvinceStateId" data-placeholder="** select province **">
                                                                <option ng-repeat="cl in ProvinceColl" ng-value="cl.id" ng-selected="cl.id==KYC.ProvinceStateId">
                                                                    {{cl.text}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>District</label>
                                                            <select class="form-control form-control-sm select2" id="cboDistrict"
                                                                    style="width: 100%;" ng-model="KYC.DistrictId" data-placeholder="** select district **">
                                                                <option ng-repeat="tdc in DistrictColl | filter: { stateId: KYC.ProvinceStateId }:true" ng-value="tdc.id" ng-selected="tdc.id==KYC.DistrictId">
                                                                    {{tdc.text}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" id="showFive">
                                                        <div class="form-group">
                                                            <label>Local Level</label>
                                                            <select class="form-control form-control-sm select2" id="cboArea"
                                                                    style="width: 100%;" ng-model="KYC.LocalLevelId" data-placeholder="** select area **">
                                                                <option ng-repeat="tdc in VDCColl| filter: { districtId: KYC.DistrictId }:true" ng-value="tdc.id" ng-selected="tdc.id==KYC.LocalLevelId">
                                                                    {{tdc.text}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label for="">Ward No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="KYC.WardNo">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="">Street Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="KYC.StreetName">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="form-group">
                                                            <label>Full Address</label>
                                                            <input type="text" placeholder="" class="form-control form-control-sm" ng-model="KYC.FullAddress" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-success btn-sm mt-4" data-toggle="modal" data-target="#exampleModalCenter">
                                                    GPS Location
                                                </button>

                                                <div class="form-group">
                                                    <label class="mt-1 mr-2" style="width:110px;">Latitude: </label>
                                                    <input type="text" placeholder="" ng-model="KYC.Lat" class="form-control form-control-sm" style="width:100%" />
                                                </div>
                                                <div class="form-group">
                                                    <label class="mt-1 mr-2" style="width:110px;">Longitude: </label>
                                                    <input type="text" placeholder="" ng-model="KYC.Lng" class="form-control form-control-sm" style="width:100%" />
                                                </div>
                                                <!-- Modal -->
                                                <div class="modal fade bd-example-modal-lg" style="margin-top:30px" id="exampleModalCenter" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                                                    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
                                                        <div class="modal-content">
                                                            <div class="modal-header p-2">
                                                                <h6 class="modal-title" id="exampleModalLongTitle">Choose Location  <u><em></em></u></h6>
                                                                <button type="button" class="close" @*data-dismiss="modal"*@ aria-label="Close" ng-click="mapClosed()">
                                                                    <span aria-hidden="true">&times;</span>
                                                                </button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <div class="row">
                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label>Latitude:{{KYC.Lat}}</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label>Longitude:{{KYC.Lng}}</label>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div id="map" style="width:100%;height:350px"></div>
                                                                </div>

                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <!-- END timeline item -->

                                <div class="time-label">
                                    <span style=" border: 1px solid #ececec;">Contact Information</span>
                                </div>
                                <!-- timeline item -->
                                <div>
                                    <div class="timeline-item">
                                        <div class="table-scroll-x-y sales-main-table table-scroll">
                                            <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                <thead>
                                                    <tr>
                                                        <th scope="col" style="width: 300px">
                                                            Name
                                                            <span style="color:red">*</span>
                                                        </th>
                                                        <th scope="col" style="width: 200px">
                                                            Designation
                                                            <span style="color:red">*</span>
                                                        </th>
                                                        <th scope="col" style="width: 230px">
                                                            <i class="fas fa-envelope text-info mr-2" style="font-size:16px;"></i>Email
                                                            <span style="color:red">*</span>
                                                        </th>
                                                        <th scope="col" style="width: 130px">
                                                            <i class="fas fa-mobile-alt text-info mr-2" style="font-size:16px;"></i>Mobile No.
                                                            <span style="color:red">*</span>
                                                        </th>
                                                        <th scope="col" style="width: 130px">
                                                            <i class="fab fa-whatsapp text-info mr-2" style="font-size:19px;"></i>Whatsapp No.
                                                        </th>
                                                        <th scope="col" style="width: 250px">Purpose of Contact</th>
                                                        <th class="cstm-sticky align-middle" scope="col" style="width: 105px; z-index: 3; right: 160px">User</th>
                                                        <th class="cstm-sticky align-middle" scope="col" style="width: 90px; z-index: 3; right: 70px">Status</th>


                                                        <th class="cstm-sticky align-middle" scope="col" style="width: 70px;z-index:3;right:0px">
                                                            Action
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="Contact in KYC.ContactDetColl">
                                                        <td>
                                                            <input type="text" ng-model="Contact.Name" class="form-control form-control-sm" />
                                                        </td>
                                                        <td>

                                                            <input type="text" ng-model="Contact.Designation" class="form-control form-control-sm" />

                                                        </td>
                                                        <td>
                                                            <input type="text" ng-model="Contact.EmailId" class="form-control form-control-sm" />
                                                        </td>

                                                        <td>
                                                            <input type="text" ng-model="Contact.MobileNo" class="form-control form-control-sm" />
                                                        </td>
                                                        <td>
                                                            <input type="text" ng-model="Contact.WhatsappNo" class="form-control form-control-sm" />
                                                        </td>

                                                        <td>
                                                            <select class="form-control form-select form-control-sm select2" @*multiple*@ ng-model="Contact.ContactPurposeId">
                                                                <option ng-repeat="P in PurposeofContactList" ng-value="P.id" ng-selected="Contact.ContactPurposeId==P.id">{{P.text}}</option>
                                                            </select>
                                                        </td>

                                                        <td class="cstm-sticky align-middle" style="z-index:2;background-color:#ffffff!important;right:160px">
                                                            <select class="form-control form-control-sm"
                                                                    style="width: 100%;" ng-model="Contact.UserName" data-placeholder="** select user **">
                                                                <option ng-repeat="ul in UserList" ng-value="ul.UserName" ng-selected="ul.UserName==Contact.UserName">
                                                                    {{ul.UserName}}
                                                                </option>
                                                            </select>
                                                        </td>

                                                        <td class="cstm-sticky align-middle" style="z-index:2;background-color:#ffffff!important;right:70px">
                                                            <div class="custom-control custom-checkbox ">
                                                                <input class="custom-control-input" type="checkbox"
                                                                       id="checkbox-sms-2-{{$index}}" value="option{{index}}" ng-model="Contact.ContactStatus">
                                                                <label for="checkbox-sms-2-{{$index}}"
                                                                       class="custom-control-label">

                                                                </label>
                                                            </div>
                                                        </td>

                                                        <td class="cstm-sticky align-middle" style="z-index:2;background-color:#ffffff!important;right:0px">
                                                            <div>
                                                                <a class="p-1" data-toggle="tooltip" ng-click="AddConctactDet($index)" data-placement="top" title="" data-original-title="View doc">
                                                                    <i class="fas fa-plus text-secondary"></i>
                                                                </a>

                                                                <a class="p-1" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delConctactDet($index)">
                                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <!-- END timeline item -->
                                <!--Attach  Document timeline time label -->
                                <div class="time-label">
                                    <span style=" border: 1px solid #ececec;">Attach  Document(s)</span>
                                </div>
                                <!--Attach  Document timeline item -->
                                <div>
                                    <div class="timeline-item p-3">
                                        <div class="add-more-than-one-form-block">
                                            <form>
                                                <article>
                                                    <div class="row p-3">
                                                        <div class="col-sm-3">
                                                            <div class="form-group">
                                                                <div class="person-photo-attachment-wrap text-center">
                                                                    <label style=" font-weight: 600;">Company Logo</label>

                                                                    <div class="img-wrap mx-auto" style="width: 140px; height: 130px;">

                                                                        <img ng-src="{{KYC.LogoData|| (KYC.attachFile+KYC.Logopath)}}" class="img-fluid" alt="" id="imgPhoto1">
                                                                    </div>
                                                                    <!-- Button trigger modal -->
                                                                    <label for="updatelogo" class="btn btn-outline-secondary btn-sm custom-file-upload">
                                                                        <i class="fas fa-camera w-t"></i>  Upload
                                                                    </label>
                                                                    <input id="updatelogo" class="form-control form-control-sm p-0" type="file" style="padding: 1px;display:none" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" file-model ng-model="KYC.Logo_TMP" fileread="KYC.LogoData" />
                                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                                    <a ng-click="ClearlogoPhoto()" class="text-danger d-block mt-1">Remove Current Logo</a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-3">
                                                            <div class="form-group">
                                                                <div class="person-photo-attachment-wrap text-center">
                                                                    <label style=" font-weight: 600;">Company Registration</label>

                                                                    <div class="img-wrap mx-auto" style="width: 140px; height: 130px;">

                                                                        <img ng-src="{{KYC.RegistrationData|| (KYC.attachFile+KYC.Registrationpath)}}" class="img-fluid" alt="" id="imgPhoto2">
                                                                    </div>
                                                                    <!-- Button trigger modal -->
                                                                    <label for="Photo-registration" class="btn btn-outline-secondary btn-sm custom-file-upload">
                                                                        <i class="fas fa-camera w-t"></i>  Upload
                                                                    </label>
                                                                    <input id="Photo-registration" class="form-control form-control-sm p-0" type="file" style="padding: 1px;display:none" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" file-model ng-model="KYC.Registration_TMP" fileread="KYC.RegistrationData" />
                                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                                    <a ng-click="CleargegistrationPhoto()" class="text-danger d-block mt-1">Remove Current File</a>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-3">
                                                            <div class="form-group">
                                                                <div class="person-photo-attachment-wrap text-center">
                                                                    <label style=" font-weight: 600;">Company PAN</label>

                                                                    <div class="img-wrap mx-auto" style="width: 140px; height: 130px;">

                                                                        <img ng-src="{{KYC.PanData|| (KYC.attachFile+KYC.Panpath)}}" class="img-fluid" alt="" id="imgPhoto3">
                                                                    </div>
                                                                    <!-- Button trigger modal -->
                                                                    <label for="Photo-pan" class="btn btn-outline-secondary btn-sm custom-file-upload">
                                                                        <i class="fas fa-camera w-t"></i>  Upload
                                                                    </label>
                                                                    <input id="Photo-pan" class="form-control form-control-sm p-0" type="file" style="padding: 1px;display:none" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" file-model ng-model="KYC.Pan_TMP" fileread="KYC.PanData" />
                                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                                    <a ng-click="ClearPanPhoto()" class="text-danger d-block mt-1">Remove Current File</a>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-3">
                                                            <div class="form-group">
                                                                <div class="person-photo-attachment-wrap text-center">
                                                                    <label style=" font-weight: 600;">Company Tax Clearance</label>

                                                                    <div class="img-wrap mx-auto" style="width: 140px; height: 130px;">

                                                                        <img ng-src="{{KYC.TaxData|| (KYC.attachFile+KYC.Taxpath)}}" class="img-fluid" alt="" id="imgPhoto4">
                                                                    </div>
                                                                    <!-- Button trigger modal -->
                                                                    <label for="Photo-tax" class="btn btn-outline-secondary btn-sm custom-file-upload">
                                                                        <i class="fas fa-camera w-t"></i>  Upload
                                                                    </label>
                                                                    <input id="Photo-tax" class="form-control form-control-sm p-0" type="file" style="padding: 1px;display:none" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" file-model ng-model="KYC.Tax_TMP" fileread="KYC.TaxData" />
                                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                                    <a ng-click="ClearTaxPhoto()" class="text-danger d-block mt-1">Remove Current File</a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </article>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <!--Attach  Document END timeline item -->
                                <!-- timeline time label -->
                                <div>
                                    <span class="d-block border-0 p-3 text-center">
                                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="UpdateKyc()">Update</button>
                                    </span>
                                </div>
                                <!-- /.timeline-label -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--Kyc Modal Ends-->

    </div>
