                            </div>*@

                    </div>
                    <div class="text-center mb-3">
                        <button type="button" class="btn btn-success  btn-sm" style="width:80px" ng-click="SendEmailToFilteredStudents()">Send</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Sibling/Filtered SMS -->
    <div class="modal fade" id="modal-sms-sfs" style="margin-top: 30px;">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">
                        Send SMS (Total filtered students: {{filteredSMSSFSStudentsCount}})
                    </h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="">Select Template</label>
                        <select class="form-control form-control-sm"
                                ng-model="selectedSMSTemplateSFS"
                                ng-options="t as t.Name for t in smsTemplatesCollSFS"
                                ng-change="OnSMSTemplateChangeSFS()">
                            <option value="">-- Select Template --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="">Title</label>
                        <input type="text"
                               class="form-control form-control-sm"
                               placeholder="Title"
                               ng-model="newSMSSFS.Title" />
                    </div>
                    <div class="form-group">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Description</label>
                            </div>
                            <div class="col-md-6 text-right">
                                Total Character: {{newSMSSFS.Description.length}}
                            </div>
                        </div>
                        <textarea class="form-control form-control-sm"
                                  rows="5"
                                  ng-model="newSMSSFS.Description"
                                  placeholder="Description"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Send To:</label><br>
                        <label class="mr-3">
                            <input type="checkbox" ng-model="sendToSFS.StudentContact"> Student Contact
                        </label>
                        <label class="mr-3">
                            <input type="checkbox" ng-model="sendToSFS.FatherContact"> Father Contact
                        </label>
                        <label class="mr-3">
                            <input type="checkbox" ng-model="sendToSFS.MotherContact"> Mother Contact
                        </label>
                        <label class="mr-3">
                            <input type="checkbox" ng-model="sendToSFS.GuardianContact"> Guardian Contact
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-sm btn-success" ng-click="SendSMSToSFSStudents()" style="min-width: 90px;">Send</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Sibling fee summary Notifications -->
    <div class="modal fade" id="modal-notification-sfs" style="margin-top: 30px;">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">Send Notification (Total filtered students : {{filteredNotificationSFSStudentsCount}})</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="">Select Template</label>
                        <select class="form-control form-control-sm"
                                ng-model="selectedNotificationTemplateSFS"
                                ng-options="t as t.Name for t in notificationTemplatesCollSFS"
                                ng-change="OnNotificationTemplateChangeSFS()">
                            <option value="">-- Select Template --</option>
                        </select>

                    </div>
                    <div class="form-group">
                        <label for="">Notification Title</label>
                        <input type="text"
                               class="form-control form-control-sm"
                               placeholder="Title"
                               ng-model="newNotificationSFS.Title"
                               maxlength="200" />
                    </div>
                    <div class="form-group">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Description</label>
                            </div>
                            <div class="col-md-6 text-right">
                                Total Character : {{newNotificationSFS.Description ? newNotificationSFS.Description.length : 0}}
                            </div>
                        </div>
                        <textarea class="form-control form-control-sm"
                                  rows="5"
                                  ng-model="newNotificationSFS.Description"
                                  placeholder="Description"
                                  maxlength="1000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="">Attach File (Optional)</label>
                        <input class="form-control form-control-sm p-0"
                               type="file"
                               style="padding: 1px"
                               accept=".jpg,.jpeg,.pdf,.doc,.docx,.png"
                               file-model
                               ng-model="newNotificationSFS.AttachmentColl" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-default"
                            ng-click="ResetNotificationSFS()"
                            style="min-width: 70px;">
                        Reset
                    </button>
                    <button type="button" class="btn btn-sm btn-success"
                            ng-click="SendManualNotificationSFSFiltered()"
                            style="min-width: 70px;"
                            ng-disabled="loadingstatusSFS=='running' || !newNotificationSFS.Title || !newNotificationSFS.Description">
                        <span ng-if="loadingstatusSFS=='running'">
                            <i class="fas fa-spinner fa-spin"></i> Sending...
                        </span>
                        <span ng-if="loadingstatusSFS!='running'">
                            Send
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>

