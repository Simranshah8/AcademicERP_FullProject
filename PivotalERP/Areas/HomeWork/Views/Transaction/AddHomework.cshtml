                                        <option ng-repeat="ct in newAddHomework.SubjectList" ng-value="ct.SubjectId" ng-selected="newAddHomework.SubjectId==ct.SubjectId">
                                            {{ct.Name}}
                                        </option>
                                    </select>
                                </div>
