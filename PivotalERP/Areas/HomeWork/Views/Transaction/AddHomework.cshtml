                        </div>
                        <div class="row" ng-if="previewAttachments.length > 0">
                            <div class="col-md-12">
                                <div class="card mt-2 mb-2">
                                    <div class="card-header p-2" style="background-color: #76be4e26">
                                        <h6 class="mb-0">
                                            <i class="fas fa-file"></i>
                                            Attachments ({{previewAttachments.length}})
                                            <span ng-if="hasExistingAttachments()" class="ml-2">
                                                <span class="badge badge-info">Existing: {{getExistingAttachmentsCount()}}</span>
                                            </span>
                                            <span ng-if="hasNewAttachments()" class="ml-1">
                                                <span class="badge badge-success">New: {{getNewAttachmentsCount()}}</span>
                                            </span>
                                        </h6>
                                    </div>
                                    <div class="card-body p-2">
                                        <div class="image-set d-flex flex-wrap">
                                            <div class="m-2 text-center position-relative" ng-repeat="file in previewAttachments track by $index + (file.isExisting ? '_existing' : '_new') + file.name">
                                                <!-- Remove button for all files -->
                                                <button type="button"
                                                        class="btn btn-danger btn-sm position-absolute"
                                                        style="top: -8px; right: -8px; border-radius: 50%; width: 25px; height: 25px; padding: 0; z-index: 10; line-height: 1;"
                                                        ng-click="removeFile($index, $event)">
                                                    <i class="fas fa-times"></i>
                                                </button>

                                                <!-- File type indicator badge -->
                                                <span class="position-absolute badge"
                                                      style="background-color: orange; color: white;left:0; font-size: 10px;"
                                                      ng-class="{'badge-info': file.isExisting, 'badge-success': !file.isExisting}">
                                                    {{file.isExisting ? 'Existing' : 'New'}}
                                                </span>

                                                <!-- Click to view -->
                                                <div ng-click="viewFile(file)" style="cursor: pointer;">

                                                    <!-- Image Preview -->
                                                    <div ng-if="file.fileType === 'image'"
                                                         style="width:130px; border:1px solid #ddd; border-radius:4px; padding:5px; background: #f8f9fa;">
                                                        <img ng-src="{{file.previewUrl}}"
                                                             alt="{{file.name}}"
                                                             style="height:100px; width:100%; object-fit: cover; border-radius: 3px;"
                                                             onerror="this.src='https://via.placeholder.com/130x100?text=Image+Error'" />
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            {{file.extension | uppercase}}
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- PDF Preview -->
                                                    <div ng-if="file.fileType === 'pdf'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file-pdf fa-4x text-danger"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            PDF
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- Word Preview -->
                                                    <div ng-if="file.fileType === 'word'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file-word fa-4x text-primary"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            Word
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- Excel Preview -->
                                                    <div ng-if="file.fileType === 'excel'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file-excel fa-4x text-success"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            Excel
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- PowerPoint Preview -->
                                                    <div ng-if="file.fileType === 'powerpoint'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file-powerpoint fa-4x text-warning"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            PowerPoint
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- Text Preview -->
                                                    <div ng-if="file.fileType === 'text'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file-alt fa-4x text-secondary"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            Text
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>

                                                    <!-- Other Files Preview -->
                                                    <div ng-if="file.fileType === 'other'"
                                                         style="width:130px; height:150px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; background: #f8f9fa;">
                                                        <i class="fas fa-file fa-4x text-secondary"></i>
                                                        <small class="d-block text-truncate mt-1" title="{{file.name}}">
                                                            {{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}
                                                        </small>
                                                        <small class="d-block text-muted">
                                                            {{file.extension | uppercase}}
                                                            <span ng-if="!file.isExisting">| {{(file.size/1024).toFixed(2)}} KB</span>
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="time-label pb-3">
                            <span class="d-block border-0 text-center">
                                <button type="button" class="btn btn-sm btn-info" id="back-homework-btn" style="min-width: 90px">
                                    Back to List
                                </button>
                                <button type="button" class="btn btn-sm btn-default" style="min-width: 90px;" ng-click="ClearAddHomework()">Reset</button>
                                <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="SaveUpdateAddHomework()">{{newAddHomework.Mode}}</button>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="modal fade" id="attachmentModalOnly" tabindex="-1" role="dialog" aria-labelledby="attachmentModalOnlyLabel" aria-hidden="true" style="margin-top: 25px;">
                    <div class="modal-dialog modal-xl" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h6 class="modal-title text-secondary" id="attachmentModalOnlyLabel">
                                    <i class="fas fa-paperclip"></i> Homework Details & Attachments
                                </h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <!-- Homework Details Section -->
                                <div class="row">
                                    <div class="col-12">
                                        <div class="card mb-0" style="border: 1px solid #bac7b369">
                                            <div class="card-header p-2" style="background-color: #76be4e26">
                                                <h6 class="mb-0"><i class="fas fa-info-circle"></i> Homework Information</h6>
                                            </div>
                                            <div class="card-body p-2">
                                                <div class="row">
                                                    <!-- Left Column -->
                                                    <div class="col-md-6">
                                                        <table class="table table-sm table-borderless">
                                                            <tr>
                                                                <th width="27%"><i class="fas fa-calendar-alt"></i> Date</th>
                                                                <td>: {{homeworkDetails.AsignDateTime_BS}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-tag"></i> Homework Type</th>
                                                                <td>: {{homeworkDetails.HomeworkTypeName || 'N/A'}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-users"></i> Class - Section</th>
                                                                <td>: {{homeworkDetails.ClassName}} <span ng-if="homeworkDetails.SectionListName"> - </span>{{homeworkDetails.SectionListName}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-book"></i> Subject</th>
                                                                <td>: {{homeworkDetails.SubjectName || 'N/A'}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th ng-if="homeworkDetails.BatchName"><i class="fas fa-layer-group"></i><span ng-if="homeworkDetails.BatchName">Batch</span> <span ng-if="homeworkDetails.SemesterName">/Semester</span><span ng-if="homeworkDetails.ClassYearName">/ClassYear</span></th>
                                                                <td>
                                                                    <span ng-if="homeworkDetails.BatchName">: {{homeworkDetails.BatchName}}</span>
                                                                    <span ng-if="homeworkDetails.SemesterName"> {{homeworkDetails.SemesterName}}</span>
                                                                    <span ng-if="homeworkDetails.ClassYearName">{{homeworkDetails.ClassYearName}}</span>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>

                                                    <!-- Right Column -->
                                                    <div class="col-md-6">
                                                        <table class="table table-sm table-borderless">
                                                            <tr>
                                                                <th width="27%"><i class="fas fa-chalkboard"></i> Lesson</th>
                                                                <td>: {{homeworkDetails.Lesson || 'N/A'}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-tasks"></i> Topic</th>
                                                                <td>: {{homeworkDetails.Topic || 'N/A'}}</td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-clock"></i> Deadline Date</th>
                                                                <td>
                                                                    :
                                                                    {{homeworkDetails.DeadlineMiti}}
                                                                    <span ng-if="homeworkDetails.DeadlineTime">at {{homeworkDetails.DeadlineTime | date:'shortTime'}}</span>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-redo-alt"></i> Redo Deadline</th>
                                                                <td>
                                                                    :
                                                                    <span ng-if="homeworkDetails.DeadlineforRedo">
                                                                        {{homeworkDetails.DeadlineforRedo | date:'dd/MM/yyyy'}}
                                                                        <span ng-if="homeworkDetails.DeadlineforRedoTime">at {{homeworkDetails.DeadlineforRedoTime | date:'shortTime'}}</span>
                                                                    </span>
                                                                    <span ng-if="!homeworkDetails.DeadlineforRedo">N/A</span>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <th><i class="fas fa-check-circle"></i> Options</th>
                                                                <td>
                                                                    :
                                                                    <span class="badge badge-success" ng-if="homeworkDetails.IsAllowLateSibmission">Late Submission Allowed</span>
                                                                    <span class="badge badge-info" ng-if="homeworkDetails.SubmissionsRequired">Submission Required</span>
                                                                    <span ng-if="!homeworkDetails.IsAllowLateSibmission && !homeworkDetails.SubmissionsRequired">No Options Set</span>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                        <div class="card mb-0" style="border: 1px solid #bac7b369">
                                            <div class="card-header p-2" style="background-color: #76be4e26">
                                                <b><i class="fas fa-align-left"></i> Description:</b>
                                            </div>
                                            <div class="card-body p-2">
                                                <p class="mb-0">{{homeworkDetails.Description || 'No description provided.'}}</p>
                                            </div>
                                        </div>
                                        <div class="card mb-0" style="border: 1px solid #bac7b369">
                                            <div class="card-header p-2" style="background-color: #76be4e26">
                                                <h6 class="mb-0"><i class="fas fa-paperclip"></i> Attachments ({{AttFilesViewOnly.length}})</h6>
                                            </div>
                                            <div class="card-body p-2">
                                                <div class="image-set m-t-20 d-flex flex-wrap">
                                                    <div class="m-2 text-center" ng-repeat="file in AttFilesViewOnly">

                                                        <!-- Image -->
                                                        <div ng-if="file.type === 'image'"
                                                             style="width:130px; cursor:pointer; border:1px solid #ddd; border-radius:4px; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <img ng-src="{{file.url}}"
                                                                 alt="{{file.name}}"
                                                                 style="height:130px; width:100%; object-fit: cover;"
                                                                 onerror="this.src='assets/images/placeholder-image.png'" />
                                                            <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                            <small class="d-block text-muted">{{file.extension | uppercase}}</small>
                                                        </div>

                                                        <!-- PDF -->
                                                        <div ng-if="file.type === 'pdf'"
                                                             style="width:130px; height:160px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <div class="text-center">
                                                                <i class="fas fa-file-pdf fa-4x text-danger"></i>
                                                                <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                                <small class="d-block text-muted">PDF</small>
                                                            </div>
                                                        </div>

                                                        <!-- Word Document -->
                                                        <div ng-if="file.type === 'word'"
                                                             style="width:130px; height:160px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <div class="text-center">
                                                                <i class="fas fa-file-word fa-4x text-primary"></i>
                                                                <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                                <small class="d-block text-muted">Word</small>
                                                            </div>
                                                        </div>

                                                        <!-- Excel Document -->
                                                        <div ng-if="file.type === 'excel'"
                                                             style="width:130px; height:160px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <div class="text-center">
                                                                <i class="fas fa-file-excel fa-4x text-success"></i>
                                                                <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                                <small class="d-block text-muted">Excel</small>
                                                            </div>
                                                        </div>

                                                        <!-- PowerPoint Document -->
                                                        <div ng-if="file.type === 'powerpoint'"
                                                             style="width:130px; height:160px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <div class="text-center">
                                                                <i class="fas fa-file-powerpoint fa-4x text-warning"></i>
                                                                <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                                <small class="d-block text-muted">PowerPoint</small>
                                                            </div>
                                                        </div>

                                                        <!-- Default/Other -->
                                                        <div ng-if="!['image','pdf','word','excel','powerpoint','text','video','audio'].includes(file.type)"
                                                             style="width:130px; height:160px; border:1px solid #ddd; border-radius:4px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; padding:5px;"
                                                             ng-click="previewFile(file)"
                                                             title="{{file.fullName || file.name}}">
                                                            <div class="text-center">
                                                                <i class="fas fa-file fa-4x text-secondary"></i>
                                                                <small class="d-block text-truncate">{{file.name | limitTo:15}}{{file.name.length > 15 ? '...' : ''}}</small>
                                                                <small class="d-block text-muted">{{file.extension | uppercase}}</small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div ng-if="!AttFilesViewOnly.length" class="text-center p-4 text-muted">
                                                    <i class="fas fa-paperclip fa-3x mb-2"></i>
                                                    <p>No attachments found for this homework.</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Attachments Section -->

                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal">
                                    Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Attachment Modal 2-->
                <div aria-hidden="true" aria-labelledby="previewModalLabel" class="modal fade" id="previewModal" role="dialog" tabindex="-1" style="margin-top:50px;">
                    <div class="modal-dialog" role="document" style="margin-top: 0; width: auto; max-width: 90vw; padding: 3px; display: flex; justify-content: center; align-items: center;">
                        <div class="modal-content" style="width: auto; display: inline-block; padding: 10px;">

                            <div class="modal-body p-0" style="padding: 10px; text-align: center;">

                                <!-- Image Preview -->
                                <img ng-if="SelectedFilePreview.type === 'image'"
                                     ng-src="{{SelectedFilePreview.url}}"
                                     alt="Preview"
                                     id="modalImage"
                                     style="display: block; width: 100%; height: auto; max-height: 70vh; object-fit: contain;" />
                                <!-- PDF Preview -->
                                <iframe ng-if="SelectedFilePreview.type === 'pdf'"
                                        ng-src="{{SelectedFilePreview.safeUrl || SelectedFilePreview.url}}"
                                        type="application/pdf"
                                        style="width: 80vw; height: 70vh; border: none;"></iframe>
                            </div>
                            <div class="modal-footer px-0 pt-2 pb-0" style="display: flex; justify-content: flex-end; gap: 3px;">
                                <a ng-href="{{SelectedFilePreview.url}}" class="btn btn-sm btn-success" target="_blank" download style="text-decoration: none; font-size: 14px;">
                                    Download
                                </a>
                                <button class="btn btn-danger btn-rounded btn-sm text-center" data-dismiss="modal" type="button" style="min-width: 80px;">
                                    Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</div>