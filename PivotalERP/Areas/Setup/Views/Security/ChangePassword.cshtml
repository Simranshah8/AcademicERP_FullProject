<script src="~/jslib/Setup/ChangePassword.js?v=20251115"></script>
<script>
    var rdVal = "@ViewBag.RD";
</script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ChangePasswordController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="row">
                    <div class="col-md-4">
                        <div class="card p-2">
                            <div class="form-group">
                                <label for="">Current password</label>
                                @*<input type="password" class="form-control form-control-sm" ng-model="newChangePassword.CurrentPassword" />*@
                                <div class="d-flex password-wrapper">
                                    <input type="password" class="form-control form-control-sm" ng-model="newChangePassword.CurrentPassword">

                                    <span class="input-group-text"
                                          style="cursor: pointer; border-left: none;"
                                          onclick="togglePassword(this)">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="">New password</label>
                                @*<input type="password" class="form-control form-control-sm" ng-model="newChangePassword.NewPassword" />*@
                                <div class="d-flex password-wrapper">
                                    <input type="password" class="form-control form-control-sm" ng-model="newChangePassword.NewPassword">

                                    <span class="input-group-text"
                                          style="cursor: pointer; border-left: none;"
                                          onclick="togglePassword(this)">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="">Confirm password</label>
                                @*<input type="password" class="form-control form-control-sm" ng-model="newChangePassword.ConfirmPassword" />*@
                                <div class="d-flex password-wrapper">
                                    <input type="password" class="form-control form-control-sm" ng-model="newChangePassword.ConfirmPassword">

                                    <span class="input-group-text"
                                          style="cursor: pointer; border-left: none;"
                                          onclick="togglePassword(this)">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                            </div>
                            <div>
                                <span>
                                    <b>Notes :-<br /></b>
                                    1. Spaces - Not Allowed <br />
                                    2. The minimum password length must be eight (8) characters.<br />
                                    3. Numeric Character - At least one character<br />
                                    4. At least one Capital Letter<br />
                                    5. Repetitive Characters - Allowed only two repetitive characters<br />
                                    6. The password must not be identical to the username.<br />
                                    7. The password must include at least one symbol(e.g., !, @@, #, $, %).<br />
                                </span>                               
                            </div>
                            <div class="time-label">
                                <span class="d-block border-0 p-3 text-center">
                                    <button type="button" class="btn btn-sm btn-default" style="min-width: 90px;" ng-click="ClearChangePassword()">Reset</button>
                                    <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="SaveUpdateChangePassword()">{{newChangePassword.Mode}}</button>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>
</div>

<script>
    function togglePassword(el) {
        // find input inside same container
        var container = el.closest('.password-wrapper');
        var pass = container.querySelector('input');
        var icon = el.querySelector('i');

        if (pass.type === "password") {
            pass.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            pass.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
</script>