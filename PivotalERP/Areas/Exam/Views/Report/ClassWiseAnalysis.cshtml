
<style>
    @@media print {
        .no-print {
            display: none !important;
        }
    }

    .custom-print-btn {
        background-color: #39bcd3;
        color: white;
        border: none;
        padding: 6px 18px;
        font-size: 14px;
        border-radius: 6px;
    }

        .custom-print-btn:hover {
            background-color: #2faac1;
            color: white;
        }

    .custom-table th {
        white-space: normal;
        word-break: break-word;
        font-size: 12px;
        line-height: 1.2;
        align-content: baseline;
    }

    .custom-table td {
        font-size: 12px;
    }

    .custom-table th,
    .custom-table td {
        padding: 4px 6px;
    }

    .fixed-table {
        table-layout: fixed;
        width: 100%;
    }

        .fixed-table th,
        .fixed-table td {
            word-wrap: break-word;
        }
</style>
<script src="~/jslib/Form/ClassWiseAnalysis.js"></script>
<div class="hold-transition  layout-navbar-fixed"
     ng-app="myApp"
     ng-controller="ClassWiseAnalysisController"
     ng-init="LoadData()">

    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <div class="root">
                        <div class="card-primary px-2 py-2 card-tabs ">
                            <div class="tab-content" id="myTabContent">
                                <div class="card p-0 mb-0">
                                    <div class=" card-body px-2 py-2" style="margin-top:-32px;">
                                        <div class="row align-items-end">
                                            <div class="col-md-1">
                                                <div class="form-group">
                                                    <select class="form-control form-control-sm" ng-model="filter.ClassType">
                                                        <option ng-repeat="pp in ClassTypeColl" ng-value="pp.id" ng-selected="pp.id==filter.ClassType">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-1">
                                                <div class="form-group">

                                                    <select class="form-control form-control-sm" ng-model="filter.SectionType">
                                                        <option ng-repeat="pp in SectionTypeColl" ng-value="pp.id" ng-selected="pp.id==filter.SectionType">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">

                                                    <select class="form-control form-control-sm" ng-model="filter.ExaminationType">
                                                        <option ng-repeat="pp in ExaminationTypeColl" ng-value="pp.id">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-1">
                                                <div class="form-group">

                                                    <select class="form-control form-control-sm" ng-model="filter.YearType">
                                                        <option ng-repeat="pp in YearTypeColl" ng-value="pp.id" ng-selected="pp.id==filter.YearType">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <select class="form-control form-control-sm" ng-model="filter.SubjectType">
                                                        <option ng-repeat="pp in SubjectTypeColl" ng-value="pp.id" ng-selected="pp.id==filter.SubjectType">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <select class="form-control form-control-sm" ng-model="filter.GradeType">
                                                        <option ng-repeat="pp in GradeTypeColl" ng-value="pp.id" ng-selected="pp.id==filter.GradeType">
                                                            {{pp.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <div class="form-group mt-2">
                                                    <button class="btn custom-print-btn no-print" onclick="window.print();">
                                                        Print
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div @*ng-repeat="group in groupedClassWiseData track by $index"*@
                                             ng-style="{'margin-top': $index == 0 ? '0px' : '20px'}">

                                            <table class="table table-bordered table-sm align-top text-start custom-table fixed-table">

                                                <!-- FIXED COLUMN WIDTHS -->
                                                <colgroup>
                                                    <col style="width:60px">
                                                    <col style="width:70px">
                                                    <col style="width:180px">
                                                    <col style="width:90px">
                                                    <col style="width:120px">
                                                    <col style="width:90px">
                                                    <col style="width:90px">
                                                    <col style="width:100px">
                                                    <col style="width:150px">
                                                    <col style="width:180px">
                                                </colgroup>

                                                <!-- Header only first table -->
                                                <thead @*ng-if="$index == 0">*@
                                                    <tr>
                                                        <th>Class</th>
                                                        <th>Section</th>
                                                        <th>Areas</th>
                                                        <th>NEPALI</th>
                                                        <th>SCIENCE AND TECHNOLOGY</th>
                                                        <th>ENGLISH</th>
                                                        <th>OUR BUTWAL</th>
                                                        <th>MATHEMATICS</th>
                                                        <th>HEALTH PHYSICAL AND CREATIVE ARTS</th>
                                                        <th>SOCIAL STUDIES AND HUMAN VALUE EDUCATION</th>
                                                    </tr>
                                                </thead>

                                                <tbody>
                                                    <tr @*ng-repeat="S in group.rows"*@>

                                                        <!-- Show Class & Section only once per table -->
                                                        <td ng-if="$first" rowspan="{{group.rows.length}}">
                                                            <strong>{{group.Class}}</strong>
                                                        </td>

                                                        <td ng-if="$first" rowspan="{{group.rows.length}}">
                                                            <strong>{{group.Section}}</strong>
                                                        </td>

                                                        <td><strong>{{S.Areas}}</strong></td>
                                                        <td class="text-start">{{S.NEPALI}}</td>
                                                        <td class="text-start">{{S.SCIENCEANDTECHNOLOGY}}</td>
                                                        <td class="text-start">{{S.ENGLISH}}</td>
                                                        <td class="text-start">{{S.OURBUTWAL}}</td>
                                                        <td class="text-start">{{S.MATHEMATICS}}</td>
                                                        <td class="text-start">{{S.HEALTH_PHYSICAL_AND_CREATIVE_ARTS}}</td>
                                                        <td class="text-start">{{S.SOCIAL_STUDIES_AND_HUMAN_VALUE_EDUCATION}}</td>

                                                    </tr>
                                                </tbody>

                                            </table>

                                        </div>


                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</div>

