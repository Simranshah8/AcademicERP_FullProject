                             onerror="this.style.visibility='hidden'">
                    </div>
                </div>

                <div class="text-section">

                    <h1 class="school-name">SHREE BHALESHWOR SECONDARY SCHOOL</h1>

                    <div class="department">
                        DEPARTMENT OF EXAMINATION
                    </div>

                    <div class="address">
                        Panauti-8, Malpi, Kavrepalanchok, 011441426
                    </div>

                    <div class="report-title">
                        IC EXAM MARK LEDGER REPORT
                    </div>

                    <div class="for-text">for</div>

                    <div class="class-text">Unknown</div>

                </div>

            </div>

            <!-- MAIN TABLE -->
            <div class="ledger-container">

                <table class="ledger-table">

                    <thead>

                        <tr>
                            <th rowspan="2">S.N.</th>
                            <th rowspan="2">Faculty/Class</th>
