        </div>
    </section>
</div>

<script>
    var body = document.getElementById("ledgerBody");

    var names = [
        "SUJATA HUMAGAIN", "UNISHA THING", "DITSA THAPA", "JASTAIN TAMANG", "SATYARAJ RUMBA",
        "RAYAN SHIVABHAKTI", "ANUGRA MILAR", "PRAKASH THING", "PHURSANG TAMANG", "KRITIKA BHANDARI",
        "SUGAM THING", "ROHIT BK", "HISHMIT GOLE", "ALVIA BISAKHE", "NISHA CHHINAL",
        "PRASAMSHA MAHAR", "AARUSH THAPA", "PRITIKA SENCHURY", "BIPLOP LIMBU", "BINA THING",
        "SURAJ TAMANG", "DILISHA TAMANG", "ASMITA PAHARI", "RIYA SHRESTHA", "SAROJ MAHARJAN",
        "PRABIN TAMANG", "SUSHMA SHAH", "ANITA KC", "MANISH SHRESTHA", "KIRAN TAMANG"
    ];

    for (let i = 0; i < names.length; i++) {

        let subjects = [];

        // generate marks for 10 subjects
        for (let j = 0; j < 10; j++) {
            subjects.push(Math.floor(Math.random() * 120) + 30);
        }

        let grades = ["A+", "A", "B+", "B", "C"];
        let grade = grades[Math.floor(Math.random() * grades.length)];

        let totalMarks = 1000;
        let obtainMarks = subjects.reduce((a, b) => a + b, 0);

        let percent = (obtainMarks / totalMarks * 100).toFixed(2);

        let gpa = (Math.random() * 4).toFixed(2);

        let result = percent >= 40 ? "Pass" : "Fail";

        body.innerHTML += `
<tr>

<td>${i + 1}</td>
<td>ONE</td>
<td>ONE-A</td>
<td>S000${50 + i}</td>
<td>${names[i]}</td>

<td>${subjects[0]}</td>
<td>${grade}</td>

<td>${subjects[1]}</td>
<td>${grade}</td>

<td>${subjects[2]}</td>
<td>${grade}</td>

<td>${subjects[3]}</td>
<td>${grade}</td>

<td>${subjects[4]}</td>
<td>${grade}</td>

<td>${subjects[5]}</td>
<td>${grade}</td>

<td>${subjects[6]}</td>
<td>${grade}</td>

<td>${subjects[7]}</td>
<td>${grade}</td>

<td>${subjects[8]}</td>
<td>${grade}</td>

<td>${subjects[9]}</td>
<td>${grade}</td>

<td>${totalMarks}</td>
<td>${obtainMarks}</td>
<td>${percent}</td>
<td>${grade}</td>
<td>${gpa}</td>
<td>${result}</td>
<td>${i + 1}</td>

</tr>
`;
    }
</script>
