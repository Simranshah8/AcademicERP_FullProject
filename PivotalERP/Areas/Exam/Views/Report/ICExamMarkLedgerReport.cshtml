                            <th colspan="2">GENERAL KNOWLEDGE</th>

                            <th rowspan="2">Total Marks</th>
                            <th rowspan="2">Obtain Marks</th>
                            <th rowspan="2">%</th>
                            <th rowspan="2">Grade</th>
                            <th rowspan="2">GPA</th>
                            <th rowspan="2">Result</th>
                            <th rowspan="2">Rank</th>

                        </tr>

                        <tr>

                            <th>TOTAL LOC</th>
