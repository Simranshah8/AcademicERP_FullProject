
<style>
    @@media print {

        @@page {
            size: A4 landscape;
            margin: 10mm;
        }

        .no-print {
            display: none !important;
        }

        .ledger-container {
            overflow: visible !important;
        }

        .ledger-table {
            width: 100%;
            font-size: 9px;
        }

        thead {
            display: table-header-group;
        }

        tfoot {
            display: table-footer-group;
        }

        tr {
            page-break-inside: avoid;
        }

        table {
            page-break-inside: auto;
        }

        /* SCALE THE PAGE CONTENT */
        .container-fluid {
            transform: scale(0.70);
            transform-origin: top left;
            width: 100%;
        }
        thead {
            display: table-header-group;
        }
    }

    .custom-print-btn {
        background-color: #39bcd3;
        color: white;
        border: none;
        padding: 6px 18px;
        font-size: 14px;
        border-radius: 6px;
    }

        .custom-print-btn:hover {
            background-color: #2faac1;
            color: white;
        }
    /*header*/
    .header-container {
        margin-bottom: 0;
        padding-bottom: 0;
        position: relative;
        text-align: center;
        font-family: Arial, sans-serif;
    }

    .logo-section {
        position: absolute;
        left: 40px;
        top: 10px;
    }

    .logo-circle {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        overflow: hidden;
    }

        .logo-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .school-name {
        font-family: "Harrington", "Lucida Calligraphy", cursive;
        font-size: 28px;
        font-weight: bold;
        margin: 0;
    }

    .department {
        font-size: 16px;
        margin-top: 5px;
        font-weight:600;
    }

    .address {
        font-size: 13px;
        margin-top: 3px;
        font-display:block;
    }

    .report-title {
        font-family: 'Montserrat', 'Poppins', 'Roboto', sans-serif;
        font-size: 22px;
        font-weight: bold;
        margin-top: 10px;
    }

    .for-text {
        margin-top: 1px;
        font-size:16px;
        font-weight:500;
    }

    .class-text {
        font-family: 'Montserrat', 'Poppins', 'Roboto', sans-serif;
        font-weight:900;
        font-size:16px;
    }
    /* ── MAIN TABLE ── */
    .ledger-container {
        width: 100%;
        overflow-x: auto;
        font-family: Arial;
    }
    .ledger-table {
        border-collapse: collapse;
        width: 100%;
        font-size: 12px;
    }

        .ledger-table th,
        .ledger-table td {
            border: 1px solid #cfcfcf;
            padding: 6px;
            text-align: center;
        }

        .ledger-table th {
            background: #f2f2f2;
            font-weight: bold;
        }

        .ledger-table td:nth-child(5) {
            text-align: left;
        }

</style>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
<div class="hold-transition layout-navbar-fixed"
     ng-app="myApp"
     ng-controller="ICExamMarkLedger1Controller"
     ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid py-2 px-2"style="margin-top:35px;">



            <!-- HEADER -->
