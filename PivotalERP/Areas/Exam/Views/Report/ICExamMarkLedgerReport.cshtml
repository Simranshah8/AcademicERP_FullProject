                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                            <th>TOTAL LOC</th>
                            <th>OVERALL OUTCOMES</th>

                        </tr>

                    </thead>

                    <tbody id="ledgerBody"></tbody>

                </table>

            </div>
            <div class="row">
                <div class="col-12 text-center mt-1">
                    <button class="btn custom-print-btn no-print" onclick="window.print();">
                        Print Ledger
                    </button>
