                { subject: "", theme: "", sn: 4, title: "Recognize, identify and produce rhyming words. (e.g. cat \u2192bat, sat)", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 5, title: "Link an initial sound to a picture of an object that begins with that sound (e.g. Show a picture of a book and identify the initial sound /b/).", grade: "A+", gp: "4.00" },
