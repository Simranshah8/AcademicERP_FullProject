                { subject: "", theme: "", sn: 11, title: ". Blend the initial sounds with other sounds, i.e. onset with rime. (e.g. c+at).", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 12, title: "Pronounce grade appropriate words correctly.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 13, title: "Ask and answer short, simple questions", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 14, title: "Sing or recite a song/chant by listening to the teacher or an audio", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 15, title: "Read small and capital letters.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 16, title: "Put sounds together to read words and sentences.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 17, title: "Recognize and read familiar words accompanied by visuals.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 18, title: "Perform rhymes and chants with appropriate rhyme and rhythm.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 19, title: "Understand the meaning of grade appropriate words .", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 20, title: "Hold pencil correctly to gain control to draw lines, curves, circles, etc.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 21, title: "Develop hand-eye coordination through drawing lines and patterns.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 22, title: "Trace the letters and write them.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 23, title: "Trace the letters and write them.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 24, title: "Demonstrate good handwriting skills.", grade: "A+", gp: "4.00" },
            ];


        };
    });
   
</script>
