@{
    ViewBag.Title = "ThemewiseGradeSheet";
}

<style>
   @@media print {
      @@page {
        size: A4 portrait;
        margin: 6mm;
      }
     .no-print {
        display: none !important;
     }

    body {
        margin: 0;
        padding: 0;
        zoom: 0.78; /* scale page to fit A4 */
    }

    .container-fluid {
        padding: 0 !important;
        margin: 0 !important;
    }
    table {
        width: 100%;
        page-break-inside: avoid;
    }
    tr {
        page-break-inside: avoid;
    }
     .header-container {
        padding: 10px;
    }

    .grade-title {
        font-size: 26px;
    }

    .gs-table th,
    .gs-table td {
        font-size: 10px;
        padding: 3px;
        line-height: 1.2;
    }

    .gs-details-table th,
    .gs-details-table td {
        font-size: 11px;
        padding: 3px 6px;
    }

    .gs-sigs {
        margin-top: 15px;
    }

   }

    .custom-print-btn {
        background-color: #39bcd3;
        color: white;
        border: none;
        padding: 6px 18px;
        font-size: 14px;
        border-radius: 6px;
    }

        .custom-print-btn:hover {
            background-color: #2faac1;
            color: white;
        }

    .form-group {
        border-radius: 18px;
    }

    .bg-light {
        background-color: #9fb3c8;
        color: #000;
    }

    .small-select {
        font-size: 12px;
        height: 30px;
    }
   /* header*/
    .header-container {
        display: flex;
        align-items: center;
        background:#fff;
        padding: 20px;
        font-family: "Times New Roman", serif;
    }

    .logo-section {
        width: 120px;
    }

        .logo-section img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
        }

    .text-section {
        flex: 1;
        text-align: center;
    }

    .tagline {
        font-size: 16px;
        margin: 0;
    }

    .text-section h2 {
        margin: 5px 0;
        font-weight: bold;
    }

    .text-section p {
        margin: 2px 0;
    }

    .text-section h3 {
        margin-top: 10px;
        font-weight: normal;
        letter-spacing: 1px;
    }
    /* ── TITLE ── */
    .title-container {
        text-align: center;
        background: #fff;
        padding: 15px 0;
        margin-top:-25px;
    }

    .grade-title {

        font-family:Impact,Charcoal,sans-serif;
        font-weight: 900;
        font-size: 36px;
        letter-spacing: 3px;
        text-decoration: underline;
        text-decoration-thickness: 4px;
        margin: 0;
    }

    /* ── META ── */
    .gs-meta {
        width: 100%;
        margin: 0 auto;
        border: 1px solid #cfcfcf;
        background: #fff;
        font-family: Arial, sans-serif;
        font-size: 16px;
    }

    .gs-meta-row {
        display: flex;
    }

        .gs-meta-row:not(:last-child) {
            border-bottom: 1px solid #cfcfcf;
        }

    .gs-meta-cell {
        flex: 1;
        padding: 8px 15px;
        display: flex;
        align-items: center;
    }

        .gs-meta-cell:first-child {
            border-right: 1px solid #cfcfcf;
        }

    .lbl {
        font-weight: normal;
        margin-right: 8px;
    }

    .val {
        font-weight: 600;
    }

    /* ── MAIN TABLE ── */
    .gs-table-wrap {
        border-bottom: 1px solid #bfbfbf;
    }

    .gs-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        font-family: Arial, sans-serif;
    }

        .gs-table th {
            border: 1px solid #bfbfbf;
            padding: 6px 8px;
            text-align: center;
            font-weight: bold;
            background: #fff;
            vertical-align: middle;
        }

        .gs-table td {
            border: 1px solid #bfbfbf;
            padding: 5px 6px;
            text-align: center;
            vertical-align: middle;
            line-height: 1.4;
        }

            .gs-table td.td-subject,
            .gs-table td.td-theme {
                font-weight: bold;
            }

            .gs-table td.td-sn {
                width: 40px;
            }
    #gradeBody td {
        border: 1px solid #cfcfcf;
        padding: 6px 8px;
        font-size: 12px;
        font-family: Arial, sans-serif;
        vertical-align: top;
    }

        #gradeBody td:nth-child(1) {
            width: 90px;
            font-weight: bold;
            text-align: center;
        }

        #gradeBody td:nth-child(2) {
            width: 90px;
            font-weight: bold;
            text-align: center;
        }

        #gradeBody td:nth-child(3) {
            width: 35px;
            text-align: center;
        }

        #gradeBody td:nth-child(4) {
            width: 420px;
            text-align: center;
            line-height: 1.5;
        }

        #gradeBody td:nth-child(5) {
            width: 70px;
            text-align: center;
        }

        #gradeBody td:nth-child(6) {
            width: 70px;
            text-align: center;
        }
        /* summary row */
        .gs-table tr.gs-summary td {
            font-weight: bold;
            background: #fff;
        }

    .gs-summary .gpa {
        text-align: right;
    }

    .gs-summary .rmk {
        text-align: left;
    }

    /* ── ABBREV + RANK ── */
    .gs-abbrev {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
        padding: 8px 12px;
        font-family: Arial, sans-serif;
        font-size: 12px;
    }

        .gs-abbrev strong {
            font-weight: bold;
        }

    .gs-rank {
        border: 2px solid #333;
        padding: 6px 14px;
        font-weight: bold;
        background: #f2f2f2;
    }

    /* ── DETAILS and signature── */
    .gs-details {
        text-align: center;
        font-family: Arial, sans-serif;
        margin-top: 15px;
    }

    .gs-details-title {
        font-weight:900;
        font-size: 16px;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .gs-details-table {
        margin: auto;
        border-collapse: collapse;
        font-size: 13px;
    }

        .gs-details-table th,
        .gs-details-table td {
            border: 1px solid #bfbfbf;
            padding: 4px 10px;
        }

        .gs-details-table th {
            background: #fff;
            font-weight: bold;
        }

    .gs-sigs {
        margin-top: 40px;
        display: flex;
        justify-content: space-between;
        padding: 0 40px;
    }

    .gs-sig {
        font-weight:600;
        width: 120px;
        border-top: 1px solid #000;
        padding-top: 5px;
        font-size: 12px;
    }

    .gs-issue {
        font-weight: 600;
        margin-top: 25px;
        font-size: 12px;
    }
</style>
<link href="https://fonts.googleapis.com/css2?family=Black+Ops+One&display=swap" rel="stylesheet">
<div class="hold-transition layout-navbar-fixed"
     ng-app="myApp"
     ng-controller="ThemewiseGradeSheetController"
     ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid py-3 px-3" style="margin-top:15px;">
            <!-- HEADER -->
            <div class="header-container">

                <div class="logo-section">

                    <img src="~/wwwroot/dynamic/images/avatar-img.png" alt="Logo" onerror="this.style.visibility='hidden'">
                </div>

                <div class="text-section">
                    <p class="tagline"><b>"Modern Education for Modern Age"</b></p>
                    <h2>SHREE BHALESHWOR SECONDARY SCHOOL</h2>
                    <p><b>Panauti-8, Malpi, Kavrepalanchok, 011441426</b></p>
                    <p><b>bhaleshwor2014@gmail.com, www.bhaleshwormavi.edu.np</b></p>
                    <h3>DEPARTMENT OF EXAMINATION</h3>
                </div>

            </div>

            <!-- TITLE -->
            <div class="title-container">
                <h1 class="grade-title">THEMEWISE GRADE-SHEET</h1>
            </div>

            <!-- META -->
            <div class="gs-meta mb-3"ng-repeat="s in student">
                <div class="gs-meta-row">
                    <div class="gs-meta-cell">
                        <span class="lbl">Reg No. :</span>
                        <span class="val">S00051{{s.regno}}</span>
                    </div>
                    <div class="gs-meta-cell">
                        <span class="lbl">Name :</span>
                        <span class="val">UNISHA THING{{s.name}}</span>
                    </div>
                </div>
                <div class="gs-meta-row">
                    <div class="gs-meta-cell">
                        <span class="lbl">Class/Sec. :</span>
                        <span class="val">ONE / ONE-A{{s.classsec}}</span>
                    </div>
                    <div class="gs-meta-cell">
                        <span class="lbl">Date of Birth :</span>
                        <span class="val">04-Jul-2015{{s.dob}}</span>
                    </div>
                </div>
            </div>

            <!-- MAIN TABLE -->
            <div class="gs-table-wrap">
                <table class="gs-table">
                    <thead>
                        <tr>
                            <th rowspan="2" style="width:65px;">Subject</th>
                            <th rowspan="2" style="width:68px;">Theme</th>
                            <th colspan="2">LOC</th>
                            <th rowspan="2" style="width:86px;">Obtained<br>Grade</th>
                            <th rowspan="2" style="width:86px;">Grade Point</th>
                        </tr>
                        <tr>
                            <th style="width:34px;">SN</th>
                            <th>Title</th>
                        </tr>
                    </thead>
                    @*<tbody id="gradeBody"></tbody>*@
                    <tbody>
                        <tr ng-repeat="d in maintable">
                            <td>{{d.subject}}</td>
                            <td>{{d.theme}}</td>
                            <td>{{d.sn}}</td>
                            <td>{{d.title}}</td>
                            <td>{{d.grade}}</td>
                            <td>{{d.gp}}</td>

                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- ABBREVIATIONS + RANK -->
            <div class="gs-abbrev">
                <span>
                    <strong>Abbreviations</strong> | TH:Theory,PR:Practical,*AB:Absent,*NG:No Grade,*MG:Missing Grade, *MP:Missing Point
                </span>
                <span class="gs-rank">RANK : 1</span>
            </div>

            <!-- DETAILS OF GRADE SHEET -->
            <div class="gs-details">
                <div class="gs-details-title">Details of Grade Sheet</div>
                <table class="gs-details-table">
                    <thead>
                        <tr>
                            <th>SN</th>
                            <th>Grade</th>
                            <th>Description</th>
                            <th>Grade Point</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>1</td><td>90.00 to 100.00</td><td>A+</td><td>Outstanding</td><td>4.00</td></tr>
                        <tr><td>2</td><td>80.00 to 90.00</td><td>A</td><td>Excellent</td><td>3.60</td></tr>
                        <tr><td>3</td><td>70.00 to 80.00</td><td>B+</td><td>Very Good</td><td>3.20</td></tr>
                        <tr><td>4</td><td>60.00 to 70.00</td><td>B</td><td>Good</td><td>2.80</td></tr>
                        <tr><td>5</td><td>50.00 to 60.00</td><td>C+</td><td>Satisfactory</td><td>2.40</td></tr>
                        <tr><td>6</td><td>40.00 to 50.00</td><td>C</td><td>Acceptable</td><td>2.00</td></tr>
                        <tr><td>7</td><td>35.00 to 40.00</td><td>D</td><td>Basic</td><td>1.60</td></tr>
                        <tr><td>8</td><td>0.00 to 35.00</td><td>NG</td><td>Not Graded</td><td>0.80</td></tr>
                    </tbody>
                </table>

                <!-- SIGNATURES -->
                <div class="gs-sigs">
                    <div class="gs-sig">Class Teacher</div>
                    <div class="gs-sig">Parents</div>
                    <div class="gs-sig">Principal</div>
                </div>

                <div class="gs-issue">DATE OF ISSUE : 2022-08-29</div>
            </div>
        </div>
        <div class="row">
            <div class="col-12 text-center mt-1">
                <button class="btn custom-print-btn no-print" onclick="window.print();">
                    Print Ledger
                </button>
            </div>
        </div>
    </section>
</div>

<script>
    app.controller("ThemewiseGradeSheetController", function ($scope) {
        $scope.LoadData = function () {
            $scope.student = [

                {
                    regNo: "S00051",
                    name: "UNISHA THING",
                    classSec: "ONE / ONE-A",
                    dob: "04-Jul-2015"
                }

            ];
            $scope.maintable = [
                { subject: "ENGLISH", theme: "ALPHABET", sn: 1, title: "Imitate, identify and discriminate sounds.", grade: "A+", gp: "4.00" },
                { subject: "", theme: "", sn: 2, title: "2. Identify words that have the same initial, medial or final sound.", grade: "A+", gp: "4.00" },
