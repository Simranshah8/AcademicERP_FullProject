
<style>
    .row {
        margin-left: -5px;
        margin-right: -5px;
    }

    .col-md-4 {
        padding-left: 5px;
        padding-right: 5px;
        margin-bottom: -15px;
    }

    .report-card {
        border-radius: 12px;
        border: 1px solid #ececec;
        cursor: pointer;
        height: 80px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .payment-report-title {
        margin-top: -25px; /* adjust as needed */
    }

    .report-card:hover {
        background-color: #d4edc9; /* slightly darker on hover */
        transform: translateY(-4px);
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.08);
    }

    .report-search {
        width: 50%;
        height: 42px;
        border-radius: 25px;
        padding-left: 20px;
        font-size: 14px;
    }

    .star-btn {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        z-index: 10;
    }

    .report-card.note-style .card-body {
        display: flex;
        padding: 0;
        height: 100%;
    }

    /* Left vertical strip */
    .note-strip {
        width: 7px;
        background: #76BE4E;
        border-radius: 12px 0 0 12px;
    }

    /* Content area */
    .note-content {
        flex: 1;
        background: #E6FFE6;
        padding: 12px 18px;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Keep height aligned */
    .report-card.note-style {
        height: 80px;
        overflow: hidden;
    }
</style>


<script src="~/jslib/exam/reporting/MasterReport.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="FinancialReportsController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <!---Practice-->
                    <div>
                        <div id="practice-section" class="card" >
                            <header class="row mb-1">
                                @*  <div class="col-md-12">
                                        <h6 class="font-weight-bold mb-2">Financial Reports</h6>
                                    </div>*@

                                <div class="col-md-12 d-flex justify-content-center">
                                    <input type="search"
                                           class="form-control report-search"
                                           placeholder="Search reports, summaries, or categories"
                                           ng-model="searchText" />
                                </div>
                            </header>
                        </div>
                        <div class="row payment-report-title">
                            <div class="col-md-12">
                                <h6 class="font-weight-bold">Payment-Centric Reports</h6>
                            </div>
                        </div>
                        <div id="practice-form" class="card p-0 mb-0">
                            <div class=" card-body px-0 py-2">
                                <div class="row">
                                    <!-- Payment -->
                                    <div class="col-md-4">
                                        <div class="card shadow-sm report-card note-style position-relative">
                                            <div class="card-body">
                                                <!-- Left green strip -->
                                                <div class="note-strip"></div>
                                                <!-- Content -->
                                                <div class="note-content">
                                                    <button class="star-btn"
                                                            ng-click="toggleStar('Payment')">
                                                        <i 
                                                           ng-class="starStatus.Payment ? 'fas fa-star text-warning' : 'far fa-star text-warning'">
                                                        </i>
                                                    </button>
                                                    <h6 class="font-weight-bold mb-1">Payment</h6>
                                                    <p class="text-muted mb-0 small">
                                                        View student payment data fee-wise
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Payment Summary -->
                                 
                                </div>
                            </div>

                         
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</div>
