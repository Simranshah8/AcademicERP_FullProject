@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="/jslib/export/tableExport.js"></script>
<script src="/jslib/export/jquery.base64.js"></script>
<script src="/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="/jslib/export/jspdf/jspdf.js"></script>
<script src="/jslib/export/jspdf/libs/base64.js"></script>

<script src="~/jslib/Exam/transaction/ObjectiveMarkEntry.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ExamTypeMarkEntryController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content" id="pills-tabContent">
                    <div class="tab-pane fade show active" id="pills-second" role="tabpanel"
                         aria-labelledby="pills-second-tab">
                        <header class="if-page-have-nav-tabs px-2">
                            <div class="row upper-tab">
                                <div class="col-md-12">
                                    <ul class="nav nav-tabs cstm-nav-tabs-border-bottom-active" id="myTab"
                                        role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <a class="nav-link active" id="home-tab" data-toggle="tab"
                                               href="#home" role="tab" aria-controls="home"
                                               aria-selected="true">Mark Entry</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </header>
                        <div class="tab-content" id="myTabContent">
                            <!-- Mark Entry Starts -->
                            <div class="tab-pane fade show active main-section" id="home" role="tabpanel"
                                 aria-labelledby="home-tab">
                                <div class="row">
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Class</label>
                                            <select class="form-control form-control-sm select2" ng-model="newFilter.SelectedClass" ng-change="GetClassSummaryClassWiseSubject(); GetStudentList();">
                                                <option ng-value="cl" ng-repeat="cl in ClassList.SectionListWithClass">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Subject</label>
                                            <select class="form-control form-control-sm select2" data-placeholder="Select Section" ng-model="newFilter.SubjectId">
                                                <option ng-value="0">**Select Subject**</option>
                                                <option ng-value="se.SubjectId" ng-repeat="se in newFilter.SubjectList">{{se.SubjectName}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Exam Type</label>
                                            <select class="form-control form-control-sm select2" ng-model="newFilter.ExamTypeId" ng-change="GetStudentList(); GetObjectiveList();">
                                                <option ng-value="0">**Select ExamType**</option>
                                                <option ng-value="cl.id" ng-repeat="cl in ExamTypeList">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-3 col-lg-3 col-md-2 mt-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input"
                                                   id="chkColumnFocus" ng-model="newFilter.ColumnWiseFocus">
                                            <label for="chkColumnFocus"
                                                   class="custom-control-label">Column Wise Focus</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="card">
                                    <header class="row">
                                        <div class="col-md-7">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar"
                                                               type="search" placeholder="Search"
                                                               aria-label="Search" ng-model="searchData.MarksEntry">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <!-- end col-md-8 -->
                                        <div class="col-md-5 text-right">
                                            <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                 data-placement="top" title="Download File">
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                        id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right"
                                                     aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item wait" export-excel table-id="'#MarksEntry'" sheet-name="'ExamTypeMarksEntry'"><img src="/wwwroot/dynamic/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" onClick="$('#MarksEntry').tableExport({type:'csv',escape:'false'});"><img src="/wwwroot/dynamic/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                </div>
                                            </div>

                                            <a print-tbl table-id="'#MarksEntry'" href="#" class="btn btn-secondary btn-light btn-sm"
                                               data-toggle="tooltip" data-placement="top" title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-success" style="min-width:70px;" ng-click="SaveUpdateMarksEntry()"> Save</button>
                                        </div>
                                    </header>
                                    <div class="table-scroll-x-y sales-main-table inputtable table-scroll mb-2" style="max-height: calc(100vh - 13rem); overflow-x: auto; ">
                                        <table id="MarksEntry" class="main-table table table-sm table-bordered bg-white">
                                            <thead>
                                                <tr>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky"
                                                        style="width: 70px; left: 0; z-index: 2; background-color: #fff">S.No.</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky"
                                                        style="width: 90px; left: 70px; z-index: 2; background-color: #fff;" ng-click="sortClassWise('RegdNo')">Regd. No</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky"
                                                        style="width: 150px; left: 160px; z-index: 2; background-color: #fff" ng-click="sortClassWise('Name')">Name</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky"
                                                        style="width: 90px; left: 310px; z-index: 2; background-color: #fff" ng-click="sortClassWise('RollNo')">Roll No</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky"
                                                        style="width: 150px; left: 310px; z-index: 2; background-color: #fff" ng-click="sortClassWise('SymbolNo')">Symbol No</th>
                                                    <th colspan="1" class="text-center align-middle cstm-sticky" style="width: 150px" ng-repeat="ct in ObjectiveList">{{ct.Name}}</th>
                                                    <th colspan="1" class="text-center align-middle cstm-sticky" style="width: 150px">Total</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 250px">Remarks</th>
                                                </tr>
                                                <tr>
                                                    <th scope="col" class="cstm-sticky text-center" style="top: 32px;" ng-repeat="ct in ObjectiveList">{{ct.Marks}}</th>
                                                    <th scope="col" class="cstm-sticky text-center" style="top: 32px;">{{ObjectiveList.TotObjMark}}</th>
                                                </tr>

                                            </thead>
                                            <tbody>
                                                @*<tr ng-repeat="st in StudentList">*@
                                                <tr dir-paginate="st in StudentList| filter:searchData.MarksEntry | itemsPerPage: perPage.MarksEntry" current-page="currentPages.MarksEntry" pagination-id="MarksEntryPagination">

                                                    <td class="text-center cstm-sticky"
                                                        style="width: 70px; left: 0px; z-index: 1; background-color: #fff">
                                                        {{$index + 1}}
                                                    </td>
                                                    <td class="text-center cstm-sticky"
                                                        style="width: 90px; left: 70px; z-index: 1; background-color: #fff">
                                                        {{st.RegNo}}
                                                    </td>
                                                    <td class="cstm-sticky" style="width: 150px; left: 160px; z-index: 1; background-color: #fff">
                                                        {{st.StudentName}}
                                                    </td>
                                                    <td class="cstm-sticky" style="width: 90px; left: 310px; z-index: 1; background-color: #fff">
                                                        {{st.RollNo}}
                                                    </td>
                                                    <td class="cstm-sticky" style="width: 150px; left: 310px; z-index: 1; background-color: #fff">
                                                        {{st.SymbolNo}}
                                                    </td>
                                                    <td class="text-center" ng-repeat="(idx, ct) in ObjectiveList">
                                                        <input type="text"
                                                               style="text-align: right;"
                                                               onfocus="this.select();"
                                                               class="form-control form-control-sm serialECAS"
                                                               ng-model="st.Marks[idx].Mark"
                                                               ng-change="ChangeMarkEntry(st, ct, idx)">
                                                    </td>
                                                    <td class="text-center">{{st.TotObjMark |number:2}}</td>
                                                    <td class="text-center"> <input type="text" class="form-control form-control-sm" ng-model="st.Remarks" /></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <footer class="row align-items-center">
                                            <div class="col-md-12">
                                                <dir-pagination-controls pagination-id="MarksEntryPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                </dir-pagination-controls>
                                            </div>
                                        </footer>
                                    </div>
                                </div>
                            </div>
                            <!-- Mark Entry Ends -->
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</div>