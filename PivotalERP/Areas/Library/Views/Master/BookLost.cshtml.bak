<style>
    .ui-grid-cell-contents {
        height: auto !important;
    }

    .ui-grid-header {
        height: 60px;
    }

    .ui-grid-filter-container .ui-grid-filter-button [class^="ui-grid-icon"] {
        position: absolute;
        top: 80%;
    }
    .t-h-10 .table td, .t-h-10 .table th {
        line-height: 1;
        padding: 0.5rem !important;
        font-size: 0.7875rem !important;
    }

    .panel-title > a, .panel-title > a:active {
        font-family: "IBM Plex Sans", sans-serif;
        display: block;
        padding: 8px 15px;
        color: #2D3333;
        font-size: 0.813rem;
        font-weight: bold;
        letter-spacing: 1px;
        word-spacing: 3px;
        text-decoration: none;
    }

    .snj-panel .panel-title a {
        display: block;
        text-decoration: none;
        background: #E9F2EE;
    }
</style>
<script src="~/jslib/library/BookLost.js"></script>

<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="BookLostController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here" style="padding-top:44px !important">
                <div id="book-lost-section">
                    <form action="">
                        <div class="row mt-2">

                            <div class="col-md-3 mt-2">
                                <div class="form-group d-flex">
                                    <label class="mt-1" style="width: 100px;">Date From</label>
                                    <input type="text"
                                           class="form-control form-control-sm ng-pristine ng-untouched ng-valid ng-isolate-scope ng-not-empty ndp-nepali-calendar"
                                           date-picker=""
                                           ng-model="newFilter.DateFrom_TMP"
                                           id="dateFrom"
                                           autocomplete="off"
                                           inputmode="text">
                                </div>
                            </div>

                            <div class="col-md-3 mt-2">
                                <div class="form-group d-flex">
                                    <label class="mt-1" style="width: 80px;">Date To</label>
                                    <input type="text"
                                           class="form-control form-control-sm ng-pristine ng-untouched ng-valid ng-isolate-scope ng-not-empty ndp-nepali-calendar"
                                           date-picker=""
                                           ng-model="newFilter.DateTo_TMP"
                                           id="dateTo"
                                           autocomplete="off"
                                           inputmode="text">
                                </div>
                            </div>

                            <div class="col-md-6 mt-2 text-right">
                                <button type="button"
                                        class="btn btn-sm btn-success"
                                        style="min-width: 70px;"
                                        ng-click="GetAllBookLostList()">
                                    <i class="fas fa-sync-alt mr-1"></i> Load
                                </button>
                                <button type="button" class="btn btn-sm btn-success" id="add-function-btn" ng-click="AddFunctionForm()" style="min-width: 90px">
                                    <i class="fas fa-plus w-t"></i>Add Book Lost/Damage
                                </button>

                            </div>


                        </div>

                    </form>
                    <div class="card p-0">

                        <div id="stSummaryDiv" ui-grid="gridOptions"
                             @*ui-grid-pagination*@
                             ui-grid-resize-columns
                             ui-grid-move-columns
                             ui-grid-selection
                             ui-grid-exporter
                             ui-grid-pinning
                             ui-grid-filtering
                             ui-grid-auto-resize
                             ui-grid-save-state style="height: calc(100vh - 170px);">
                        </div>

                    </div>

                </div>

                <div id="add-function-form" style="padding-top: 12px !important">
                    <form name="addFunctionForm" novalidate>
                        <div class="row">

                            <div class="col-md-9">
                                <div class="row">
                                    @*<div class="col-md-10 mb-2">
            <label>Book Selection</label>
            <div class="input-group-prepend">
                <select class="input-group-text dropdown-toggle p-0 text-truncate" style="outline: none; border-top-right-radius: unset; border-bottom-right-radius: unset; width: 100px; margin-right: -3px; z-index: 1; font-size: 13px;" ng-model="newLostDamage.SelectBook">
                    <option ng-repeat="ss in BookSearchOptions" ng-value="ss.value" ng-selected="ss.value==newLostDamage.SelectBook"> {{ss.text}} </option>
                </select>
                <select class="form-control select2 form-control-sm" style="max-width: calc(100% - 100px);" all-book ng-model="newLostDamage.BookEntryId" book-detail="newLostDamage.BookDetails" side-bar-data="newLostDamage.SideBarData" search-by="newLostDamage.SelectBook" for-report="true" confirm-action="ShowBookDetails()" showdetails="true">
                </select>
            </div>
        </div>*@
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Issue To</label>
                                            <select class="form-control form-control-sm" ng-model="newLostDamage.IssueTo">
                                                <option ng-value="it.id" ng-repeat="it in IssueToList">{{it.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-9 col-lg-9 col-md-9" id="meet-student" ng-show="newLostDamage.IssueTo == 1">
                                        <div class="custom-control custom-checkbox text-right">
                                            <input class="custom-control-input" type="checkbox" ng-model="newLostDamage.ShowLeftStudent" id="customCheckbox111" value="option1">
                                            <label for="customCheckbox111" class="custom-control-label">  Show Left Student </label>
                                        </div>
                                        <div class="input-group-prepend">
                                            <select class="input-group-text dropdown-toggle p-0" style="outline: none; width:20%; border-top-right-radius: unset; border-bottom-right-radius: unset; margin-right: -3px;  z-index: 1; " ng-model="newLostDamage.SelectStudent">
                                                <option class="dropdown-item" ng-repeat="ss in StudentSearchOptions" ng-value="ss.value" ng-selected="{{ss.value==newLostDamage.SelectStudent}}"> {{ss.text}} </option>
                                            </select>
                                            <select class="form-control select2 form-control-sm" style="width:80%;" all-student ng-model="newLostDamage.StudentId" student-detail="newLostDamage.StudentDetails" include-left="newLostDamage.ShowLeftStudent" side-bar-data="newLostDamage.SideBarData" search-by="newLostDamage.SelectStudent" confirm-action="getStudentDetails()">
                                            </select>

                                        </div>
                                    </div>
                                    <!-- Field For meet Teacher -->
                                    <div class="col-sm-9 col-lg-9 col-md-9" id="meet-employee" ng-show="newLostDamage.IssueTo == 2">
                                        <label>Teacher</label>
                                        <div class="input-group-prepend">
                                            <select class="input-group-text dropdown-toggle p-0" style="outline: none; width:20%; border-top-right-radius: unset; border-bottom-right-radius: unset; margin-right: -3px; z-index: 1; " ng-model="newLostDamage.SelectEmployee">
                                                <option class="dropdown-item" ng-repeat="ss in EmployeeSearchOptions" ng-value="ss.value" ng-selected="ss.value==newLostDamage.SelectEmployee">{{ss.text}}</option>
                                            </select>
                                            <select class="form-control select2bs4 form-control-sm" style="width:80%;" all-employee ng-model="newLostDamage.EmployeeId" employee-detail="newLostDamage.EmployeeDetails" side-bar-data="newLostDamage.EmpSideBarData" search-by="newLostDamage.SelectEmployee" confirm-action="getTeachCreditRule()">
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Book Selection</label>
                                            <select class="form-control form-control-sm select2" ng-model="newLostDamage.BookDetailsCo" ng-change="GetBookDetails(newLostDamage.BookDetailsCo)">
                                                <option ng-repeat="BD in PreviousBookDetailsColl" ng-value="BD">
                                                    {{BD.AccessionNo}} - {{BD.BookTitle}} - {{BD.Subject}} - {{BD.Authors}}
                                                </option>


                                                @*<option ng-repeat="BD in PreviousBookDetailsColl" ng-value="BD">{{BD.AccessionNo}} - {{BD.BookTitle}} - {{BD.Subject}} - {{BD.Authors}}</option>*@
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Issue Date</label>
                                            <input type="text" class="form-control form-control-sm ndp-nepali-calendar"
                                                   ng-model="newLostDamage.IssueDate_TMP" date-picker date-detail="newLostDamage.IssueDateDet">
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Outstanding Days</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="newLostDamage.OutstandingDays">
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Fine Amount</label>
                                            <input type="text" class="form-control form-control-sm">
                                            <label class="float-right ng-binding" ng-show="newLostDamage.IssueTo == 1">Dues Fee : {{CurDues.TotalDues | number:2}}/-</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Lost/Damage</label>
                                            <select class="form-control form-control-sm"
                                                    ng-model="newLostDamage.LostDamage">
                                                <option ng-value="it.id" ng-repeat="it in LostDamageList">{{it.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Lost/Damage Date</label>
                                            <input type="text" class="form-control form-control-sm ndp-nepali-calendar"
                                                   ng-model="newLostDamage.LostDamageDate_TMP" date-picker date-detail="newLostDamage.LostDamageDateDet">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Remarks</label>
                                            <textarea class="form-control form-control-sm" ng-model="newLostDamage.Remarks" style="height:30px"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="wrapper ">
                                    <div class="panel-group snj-panel" id="accordion" role="tablist" aria-multiselectable="true">

                                        <div class="panel panel-default" id="stu_Details" ng-show="newLostDamage.IssueTo==1">
                                            <div class="panel-heading active" role="tab" id="headingOne" style="background: #E9F2EE;">
                                                <h4 class="panel-title">
                                                    <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseOne"
                                                       aria-expanded="true" aria-controls="collapseOne">
                                                        Student Details
                                                    </a>
                                                </h4>
                                            </div>
                                            <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel"
                                                 aria-labelledby="headingOne">
                                                <div class="panel-body">
                                                    <div class="col-sm-12 col-md-12 col-lg-12">
                                                        <div class="row">
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                @*<img src="~/wwwroot/dynamic/images/fee_receipt/profile_30.png">*@
                                                                <img style="height:50px; width:50px;" class="rounded-circle" ng-src="{{CurDues.PhotoPath}}" />
                                                            </div>
                                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                                <span class="s-text">Name</span><br>
                                                                <span><b>{{CurDues.Name}}</b></span><br>
                                                            </div>
                                                        </div>
                                                        <div class="row mt-2">
                                                            <div class="col-sm-7 col-md-7 col-lg-7">
                                                                <span class="s-text">Adm. No.: </span>
                                                                <b>  <span>{{CurDues.RegdNo}}</span></b>
                                                            </div>
                                                            <div class="col-sm-5 col-md-5 col-lg-5">
                                                                <span class="s-text">Roll :</span>
                                                                <b> <span>{{CurDues.RollNo}}</span></b>
                                                            </div>
                                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                                <span>
                                                                    Class: <b>
                                                                        <span>
                                                                            {{CurDues.ClassName ? CurDues.ClassName : ''}}
                                                                            {{CurDues.SectionName ? ' - ' + CurDues.SectionName : ''}}
                                                                            {{CurDues.Batch ? ' - ' + CurDues.Batch : ''}}
                                                                            {{CurDues.Semester ? ' - ' + CurDues.Semester : ''}}
                                                                            {{CurDues.ClassYear ? ' - ' + CurDues.ClassYear : ''}}
                                                                        </span>
                                                                    </b>
                                                                </span>
                                                            </div>
                                                        </div>

                                                        <div class="row mt-2">
                                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                                <span class="s-text">Address : </span>
                                                                <b> <span>{{CurDues.Address}}</span></b>
                                                            </div>
                                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                                <span class="s-text">Father Name : </span>
                                                                <b> <span>{{CurDues.FatherName}}</span></b>
                                                            </div>
                                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                                <span class="s-text">Contact : </span>
                                                                <b>  <span>{{CurDues.ContactNo}}</span></b>
                                                            </div>
                                                        </div>
                                                        <!--Field added by suresh on 25 kartik starts-->
                                                        <div class="row mt-2">
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span class="s-text" title="Book Limit">B. Limit: </span>
                                                                <span>{{CurDues.BookLimit}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span class="s-text" title="Credit Days">C. Days: </span>
                                                                <span>{{CurDues.BookCreditDays}}</span>
                                                            </div>

                                                        </div>
                                                        <!--ends-->

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="panel panel-default" id="emp_Details" ng-show="newLostDamage.IssueTo==2">
                                            <div class="panel-heading active" role="tab" id="headingOne" style="background: #E9F2EE;">
                                                <h4 class="panel-title">
                                                    <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseOne"
                                                       aria-expanded="true" aria-controls="collapseOne">
                                                        Employee Details
                                                    </a>
                                                </h4>
                                            </div>
                                            <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel"
                                                 aria-labelledby="headingOne">
                                                <div class="panel-body">
                                                    <div class="col-sm-12 col-md-12 col-lg-12">
                                                        <div class="row">
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <img ng-src="{{DefaultPhoto}}" style="height:50px; width:50px;" class="rounded-circle" />
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span><b>{{newLostDamage.EmployeeDetails.Name}}</b></span><br>
                                                                <span>{{newLostDamage.EmployeeDetails.Designation}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4" title="Employee Code">
                                                                <span class="s-text">E. Code</span><br>
                                                                <span>{{newLostDamage.EmployeeDetails.Code}}</span>
                                                            </div>
                                                        </div>
                                                        <div class="row mt-2">
                                                            <div class="col-sm-4 col-md-4 col-lg-4" title="Contact No.">
                                                                <span class="s-text">C. No.</span><br>
                                                                <span>{{newLostDamage.EmployeeDetails.MobileNo}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span class="s-text">Address</span><br>
                                                                <span>{{newLostDamage.EmployeeDetails.Address}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4" title="Subject Teacher">
                                                                <span class="s-text">S. Teacher</span><br>
                                                                <span>{{newLostDamage.EmployeeDetails.SubjectTeacher}}</span>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- BOOK LOST SECTION  -->
                                        <div class="panel panel-default">
                                            <div class="panel-heading current_due" role="tab" id="headingOne" style="background: #E9F2EE;">
                                                <h4 class="panel-title">
                                                    <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseThree"
                                                       aria-expanded="true" aria-controls="collapseOne">
                                                        Book Details
                                                    </a>
                                                </h4>
                                            </div>
                                            <div id="collapseThree" class="panel-collapse collapse show" role="tabpanel"
                                                 aria-labelledby="headingThree">
                                                <div class="panel-body">
                                                    <div class="col-md-12" style="font-size: 0.7rem;">
                                                        <div class="row">
                                                            <div class="col-sm-9 col-md-9 col-lg-9">
                                                                <span><b>Book Title</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.BookTitle}}</span>
                                                            </div>
                                                            <div class="col-sm-3 col-md-3 col-lg-3 float-right">
                                                                <a href="#" data-target="#modalIMG-general" data-toggle="modal" class="color-gray-darker c6 td-hover-none ">
                                                                    <div class="ba-0 ds-1">
                                                                        <img ng-src="{{newLostDamage.BookDetails.FrontCoverPath}}" style="height: 60px; width: 100%;">

                                                                    </div>
                                                                </a>
                                                                <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="modalIMG-general" role="dialog" tabindex="-1">
                                                                    <div class="modal-dialog modal-lg" role="document">
                                                                        <div class="modal-content">
                                                                            <div class="modal-body mb-0 p-0">
                                                                                <img ng-src="{{newLostDamage.BookDetails.FrontCoverPath}}" alt="" style="width:100%; height: 30vh;" class="d-flex mx-auto">
                                                                            </div>
                                                                            <div class="modal-footer">
                                                                                <!-- <div><a href="dynamic/images/book-1.png" target="_blank" download>Download</a></div> -->
                                                                                <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="col-sm-4 col-md-4 col-lg-4 " style="margin-top: -15px;">
                                                                <span class="s-text"><b>Bar Code</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.Barcode}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4 " style="margin-top: -15px;">
                                                                <span class="s-text"><b>Subject</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.Subject}}</span>
                                                            </div>


                                                        </div>
                                                        <div class="row mt-3">
                                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                                <span class="s-text"><b>Authors</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.Authors}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span class="s-text"><b>Credit Days</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.CreditDays}} Days</span>
                                                            </div>
                                                            <div class="col-sm-12 col-md-12 col-lg-12 mt-3">
                                                                <span class="s-text"><b>Publisher</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.Publication}}</span>
                                                            </div>
                                                            <div class="col-sm-12 col-md-12 col-lg-12 mt-3">
                                                                <span class="s-text"><b>Category</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.BookCategory}}</span>
                                                            </div>
                                                        </div>
                                                        <div class="row mt-3">
                                                            <div class="col-sm-4 col-md-4 col-lg-4">
                                                                <span class="s-text"><b>Level</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.ClassName}}</span>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 col-lg-4 ">
                                                                <span class="s-text"><b>Department</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.Department}}</span>
                                                            </div>
                                                            <!--Field added by suresh on 25 kartik starts-->
                                                            <div class="col-sm-4 col-md-4 col-lg-4 ">
                                                                <span class="s-text"><b>Class</b></span><br>
                                                                <span>{{newLostDamage.BookDetails.ClassName}}</span>
                                                            </div>
                                                            <!--ends-->
                                                        </div>


                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>



                            </div>
                        </div>
                        <div class="time-label">
                            <span class="d-block border-0 p-3 text-center">

                                <button type="button" id="detailsback-btn" class="btn btn-sm btn-info" style="min-width: 90px" ng-click="cancelAddFunction()">Back to List</button>
                                <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="CallSaveBookLostDetail()">Save</button>

                            </span>
                        </div>
                    </form>
                </div>

            </section>
            <!-- /.row -->

        </div>
        <!--/. container-fluid -->
    </section>

    <!-- /.content -->
    <!-- Add ReportTemplates Modal Dailog -->

</div>

