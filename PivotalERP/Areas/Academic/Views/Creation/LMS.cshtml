<style>
    .lesson_tab .tab-content {
        background: #F6FAF8;
        padding: 10px !important;
    }

    table thead tr {
        background-color: #b4e1f4 !important;
    }

    .table-scroll-x-y table thead th, .table.table-head-fixed thead tr th {
        background-color: #0b605f !important;
        color: aliceblue !important;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: #e5f2ff;
        font-weight: 500;
    }

    .table-striped tbody tr:nth-of-type(even) {
        background-color: #eef9f4;
        font-weight: 500;
    }

    .custom-checkbox .custom-control-input:checked ~ .custom-control-label::after {
        background-color: #025a58;
        border-radius: 4px;
    }

    .imgtoprevlist {
        height: 100px;
        width: auto;
    }

    .fullimg {
        width: auto;
        height: 600px;
        object-fit: cover;
    }

    .tree li span {
        background-color: aliceblue;
        border: 1px solid #d5e8fc;
        box-shadow: rgba(100, 100, 111, 0.2) 0px 7px 29px 0px;
    }
    .subt, .add {
        height: 90px!important;
    }
    .selected-topic {
        background: linear-gradient(135deg, #2e7d32, #66bb6a) !important;
        color: #fff !important;
        font-weight: 600;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

        .selected-topic a {
            color: #fff !important;
        }
    .page-item.active .page-link {
        background-color: #28a745 !important;
        border-color: #28a745 !important;
        color: #fff !important;
    }
    .card .card-body {
        display: block;
    }

    .card.collapsed-card .card-body {
        display: none;
    }

    .card.collapsed-card .card-collapsed {
        display: inline-block;
    }

    .card.collapsed-card .card-expanded {
        display: none;
    }

    .card:not(.collapsed-card) .card-collapsed {
        display: none;
    }

    .card:not(.collapsed-card) .card-expanded {
        display: inline-block;
    }
</style>
<link href="~/wwwroot/dynamic/css/lms.css" rel="stylesheet" />
<link href="~/wwwroot/dynamic/css/lessonplan.css" rel="stylesheet" />
<script src="~/jslib/academic/creation/LMS.js?v=@AcademicLib.BE.Global.AppVer.Ver"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="LMSController" ng-cloak ng-init="LoadData()">
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content" id="pills-tabContent">
                    <div class="tab-pane fade show active" id="pills-second" role="tabpanel"
                         aria-labelledby="pills-second-tab">
                        <!-- if-page-have-nav-tabs -->
                        <header class="if-page-have-nav-tabs px-2">
                            <div class="row upper-tab">
                                <div class="col-md-12">
                                    <ul class="nav nav-tabs cstm-nav-tabs-border-bottom-active" id="myTab" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <a class="nav-link active" id="english-tab" data-toggle="tab" href="#english" role="tab"
                                               aria-controls="english" aria-selected="true">Add Lesson Content</a>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <a class="nav-link" id="science-tab" data-toggle="tab" href="#lms2" role="tab"
                                               aria-controls="science" aria-selected="false">Lesson Content List</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </header>
                        <!-- end if-page-have-nav-tabs -->
                        <div class="tab-content" id="myTabContent">
                            <div class="tab-pane fade show active main-section" id="english" role="tabpanel"
                                 aria-labelledby="english-tab">
                               
                                <div class="row mt-2">
                                    <div class="col-sm-3 col-lg-3 col-md-3" ng-show="AcademicConfig.ActiveBatch==true">
                                        <div class="form-group d-flex">
                                            <label class="mt-1 mr-2">Batch</label>
                                            <select class="form-control form-control-sm select2" ng-model="newAddLessonContent.BatchId" style="width:100%">
                                                <option ng-value="0">**Select Batch**</option>
                                                <option ng-value="cl.id" ng-repeat="cl in BatchList" ng-selected="cl.id==newLessonContentList.BatchId">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group d-flex">
                                            <label class="mt-1 mr-2">Class</label>
                                            <select class="select2 form-control-sm" data-placeholder="Select Section" style="width:100%" ng-model="newAddLessonContent.SelectedClass" ng-change="GetClassWiseSubjectList()">
                                                <option ng-value="null">**Select Class**</option>
                                                <option ng-value="se" ng-repeat="se in ClassSection.ClassList">{{se.text}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-3" ng-show="newAddLessonContent.SelectedClass.ClassType==2  &&  AcademicConfig.ActiveClassYear==true">
                                        <div class="form-group mb-0 d-flex">
                                            <label class="mt-1 mr-2" style="width:80px;">Class Year</label>
                                            <select class="form-control form-control-sm select2" ng-model="newAddLessonContent.ClassYearId" ng-change="GetClassWiseSubjectList()" style="width:100%">
                                                <option ng-value="0">**Select Year**</option>
                                                <option ng-value="cl.id" ng-repeat="cl in ClassYearList" ng-selected="cl.id==newAddLessonContent.ClassYearId">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3" ng-show="newAddLessonContent.SelectedClass.ClassType==3 &&  AcademicConfig.ActiveSemester==true">
                                        <div class="form-group mb-0 d-flex">
                                            <label class="mt-1 mr-2">Semester</label>
                                            <select class="form-control form-control-sm select2" ng-model="newAddLessonContent.SemesterId" ng-change="GetClassWiseSubjectList()" style="width:100%">
                                                <option ng-value="0">**Select Semester**</option>
                                                <option ng-value="cl.id" ng-repeat="cl in SemesterList" ng-selected="cl.id==newAddLessonContent.SemesterId">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group d-flex">
                                            <label class="mt-1 mr-2">Subject</label>
                                            <select class="form-control form-control-sm select2" style="width:100%" ng-model="newAddLessonContent.SubjectId" ng-change="GetLessonPlanByClassSubject(newAddLessonContent.SelectedClass.ClassId,newAddLessonContent.SubjectId)">
                                                <option ng-value="cl.id" ng-repeat="cl in SubjectList" ng-selected="cl.id==newAddLessonContent.SubjectId">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div ng-if="!newAddLessonContent.SelectedClass ||!newAddLessonContent.SelectedClass.ClassId ||!newAddLessonContent.SubjectId"
                                     style="background: linear-gradient(135deg, #e9f7e4, #f4fbf1); border-left: 8px solid #76BE4E;color: #2f5e1f;padding: 18px 20px;margin-top: 12px;border-radius: 16px;
                                     font-size: 16px;line-height: 1.7;display: flex;align-items: flex-start; gap: 12px;">
                                    <div style="font-size: 26px; line-height: 1;">⚠️</div>
                                    <div>
                                        <div style="font-size:18px; font-weight:600; color:#025a58; margin-bottom:4px;">
                                            Required
                                        </div>
                                        Please select <b>Class</b> and <b>Subject</b> and Other Required Parameters first.
                                    </div>
                                </div>

                                <div ng-if="newAddLessonContent.SelectedClass.ClassId && newAddLessonContent.SubjectId &&(!newAddLessonContent.DetailsColl || newAddLessonContent.DetailsColl.length == 0)"
                                     style="background: linear-gradient(135deg, #e6f4f3, #f2fbfa);border-left: 8px solid #025a58;color: #024846;padding: 18px 20px;
                                     margin-top: 12px;border-radius: 16px;font-size: 16px;line-height: 1.7;display: flex;align-items: flex-start;gap: 12px;">
                                    <div style="font-size: 26px; line-height: 1;margin-top:10px">ℹ️</div>
                                    <div>
                                        <div style="font-size:18px; font-weight:600; color:#025a58; margin-bottom:4px;">
                                            No Data Available
                                        </div>
                                        No lesson and topics are available.<br>
                                        Please go to <b>Add Lesson </b> menu and add the Lesson and Topics.
                                    </div>
                                </div>
                                <div class="row" ng-show="newAddLessonContent.SelectedClass && newAddLessonContent.SubjectId &&  newAddLessonContent.DetailsColl.length > 0">
                                    <div class="col-md-4">
                                        <label><b>{{newAddLessonContent.NoOfLesson}} lesson & its Topics</b></label>
                                        <div class="tree" style="height: 515px;overflow-y: auto;">
                                            <ul class="card p-0" style="padding-left: 0px;margin-bottom: 6px;" ng-repeat="ld in newAddLessonContent.DetailsColl">
                                                <li>
                                                    <span data-toggle="collapse" style=" background-color: #b4e1f4;">
                                                        <a style="color:#000; text-decoration:none;" data-toggle="collapse" href="#Web" aria-expanded="true"
                                                           aria-controls="Web">
                                                            <i class="collapsed"><i class="fas fa-folder"></i></i>
                                                            <i class="expanded"><i class="far fa-folder-open"></i></i> {{ld.SNo}}. {{ld.LessonName}}
                                                        </a>
                                                    </span>
                                                    <div id="Web" class="collapse show" style="background-color: #d7ecf5;">
                                                        <ul class="pb-3">
                                                            <li ng-repeat="tc in ld.TopicColl" ng-click="ClickOnTopic(ld,tc)"><span ng-class="{'selected-topic': selectedKey == (ld.LessonId + '_' + tc.SNo)}">{{ld.SNo}}.{{tc.SNo}} <a href="#!" ng-click="ClickOnTopic(ld,tc)"> {{tc.TopicName}}</a></span></li>
                                                        </ul>
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="row">
                                            <div class="col-md-12 lesson_tab" style="border: 1px solid #c9efff; padding: 0; border-radius: 7px;">
                                                <ul class="nav nav-tabs" role="tablist" style="background-color: #d6f3ff; border-radius: 7px; ">
                                                    <li class="nav-item">
                                                        <a class="nav-link active" data-toggle="tab" href="#tabs-1" role="tab">Contents</a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a class="nav-link" data-toggle="tab" href="#tabs-2" role="tab">Videos</a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a class="nav-link" data-toggle="tab" href="#tabs-3" role="tab">Quiz</a>
                                                    </li>
                                                </ul>
                                                <!-- Tab panes -->
                                                <div class="tab-content" style="height: auto !important;background-color:#ffffff!important;margin:0!important">
                                                    <div class="tab-pane active" id="tabs-1" role="tabpanel">
                                                        <p class="mt-2 mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.LessonName">.</span>{{CurrentLessionTopic.LessonName}}</b></p>
                                                        <p><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.TopicSNo">.</span>{{CurrentLessionTopic.TopicSNo}} {{CurrentLessionTopic.TopicName}}</b></p>
                                                        <div class="row upload_img" ng-show="CurrentLessionTopic.LessonId>0">
                                                            <div class="col-md-2">
                                                                <div class="add">
                                                                    <div class="upload-btn-wrapper">
                                                                        <button class="btn"><i class="fas fa-link"></i><br>Upload</button>
                                                                        <input type="file" name="myfile" file-models ng-model="CurrentLessionTopic.TMPContentsColl" after-selected="ChooseContentFile()" @*fileread="CurrentLessionTopic.TMPContent"*@ />
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-2" ng-repeat="cc in CurrentLessionTopic.ContentsColl">
