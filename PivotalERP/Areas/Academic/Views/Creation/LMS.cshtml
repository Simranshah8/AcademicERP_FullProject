                                                                            <tr>
                                                                                <th style="width: 250px;">Title</th>
                                                                                <th style="width: 90px;">No.of Questions</th>
                                                                                <th style="width: 100px;">Time Duration(min)</th>
                                                                                <th style="width: 70px;">FM</th>
                                                                                <th style="width: 70px;">PM</th>
                                                                                <th style="width: 90px;">Action</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <tr ng-repeat="Q in LessonTopicQuizList">
                                                                                <td>{{Q.Topic}}</td>
                                                                                <td>{{Q.NoOfQuestion}}</td>
                                                                                <td>{{Q.Duration}} min</td>
                                                                                <td>{{Q.FullMark}}</td>
                                                                                <td>{{Q.PassMark}}</td>
                                                                                <td>
                                                                                    @*<a class="p-1" href="#" id="preview">
                                                                <i class="fas fa-eye text-success"></i>
                                                            </a>*@
                                                                                    <a class="p-1" ng-click="GetLessonTopicQuizId(Q)">
                                                                                        <i class="fas fa-edit text-info"></i>
                                                                                    </a>
                                                                                    <a class="p-1" ng-click="DeleteLessonTopicQuizId(Q)">
                                                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                                                    </a>
                                                                                </td>
                                                                            </tr>

                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div id="quizform">
                                                            <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<spn ng-if="CurrentLessionTopic.LessonName">.</spn>{{CurrentLessionTopic.LessonName}}</b></p>
                                                            <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.TopicSNo">.</span>{{CurrentLessionTopic.TopicSNo}} {{CurrentLessionTopic.TopicName}}</b></p>
                                                            <div class="row">
                                                                <div class="col-md-6">
                                                                    <div class="row">
                                                                        <div class="col-md-12">
                                                                            <div class="form-group">
                                                                                <label>Title</label>
                                                                                <input type="text" class="form-control form-control-sm" ng-model="CurrentLessionTopic.Quiz.Topic">
                                                                            </div>
                                                                        </div>
