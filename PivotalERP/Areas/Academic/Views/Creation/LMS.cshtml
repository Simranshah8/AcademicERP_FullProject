                                                                    <a href="#" ng-click="DocumentAtt_Toggle(cc)" data-toggle="modal" class="color-gray-darker c6 td-hover-none">
                                                                        <div class="ba-0 ds-1">
                                                                            <img src="~/wwwroot/dynamic/images/flaticons/pdf.png" style="max-height:50px;" />
                                                                        </div>
                                                                    </a>
                                                                </div>
                                                                <div class="text-center mb-3">
                                                                    <label>{{cc.Name}}</label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div ng-show="!CurrentLessionTopic.LessonId" style="background: linear-gradient(135deg, #e8f5e9, #ffffff);border-left: 6px solid #4caf50;
                                                            color: #1f4d2e;padding: 16px 20px;margin-top: 12px;border-radius: 14px;font-size: 15px;line-height: 1.6;display: flex;align-items: center;
