                                                                <div class="col-md-10">
                                                                    <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<spn ng-if="CurrentLessionTopic.LessonName">.</spn>{{CurrentLessionTopic.LessonName}}</b></p>
                                                                    <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.TopicSNo">.</span>{{CurrentLessionTopic.TopicSNo}} {{CurrentLessionTopic.TopicName}}</b></p>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <div class="float-right">
                                                                        <button class="btn btn-sm btn-success" id="AddVideoBtn"><i class="fas fa-plus"></i> Add Video</button><br>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-md-6" ng-repeat="vt in CurrentLessionTopic.VideoColl">
                                                                    <div class="card mb-2"
                                                                         ng-if="vt.Link && vt.Link != ''"
                                                                         style="background-color:#ffffff!important;border:1px solid #ccc">

                                                                        <div class="card-header p-2">
                                                                            <h3 class="card-title">{{$index+1}}. {{vt.Title}}</h3>
                                                                        </div>

                                                                        <div class="card-body p-2">
                                                                            <iframe style="width:300px; height:180px; border:0;"
                                                                                    ng-src="{{vt.Link | trusted}}">
                                                                            </iframe>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div id="addVideo">
                                                            <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<spn ng-if="CurrentLessionTopic.LessonName">.</spn>{{CurrentLessionTopic.LessonName}}</b></p>
                                                            <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.TopicSNo">.</span>{{CurrentLessionTopic.TopicSNo}} {{CurrentLessionTopic.TopicName}}</b></p>
                                                            <div class="">
                                                                <div class="table-scroll-x-y sales-main-table table-scroll">
                                                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                                        <thead>
                                                                            <tr>
                                                                                <th style="width: 40px">S.No</th>
                                                                                <th style="width: 200px">Video Title</th>
                                                                                <th style="width: 170px">Video Link</th>
                                                                                <th style="width: 220px">Remarks</th>
                                                                                <th style="width: 60px">Action</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <tr ng-repeat="vt in CurrentLessionTopic.VideoColl">
                                                                                <td>{{$index+1}}</td>
                                                                                <td><input type="text" class="form-control form-control-sm" ng-model="vt.Title" /></td>
                                                                                <td><input type="text" class="form-control form-control-sm" ng-model="vt.Link" /></td>
                                                                                <td><input type="text" class="form-control form-control-sm" ng-model="vt.Remarks" /></td>
                                                                                <td>
                                                                                    <a class="p-1" ng-click="AddVideo($index)" href="#" data-toggle="tooltip" data-placement="top" title="Edit">
                                                                                        <i class="fas fa-plus text-info"></i>
                                                                                    </a>
                                                                                    <a class="p-1" href="#" ng-click="delVideo($index)" data-toggle="tooltip" data-placement="top" title="Delete">
                                                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                                                    </a>
                                                                                </td>
                                                                            </tr>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                                <div class="time-label text-center">
                                                                    <span class="d-block border-0 p-3 mt-4">
                                                                        <button type="button" class="btn btn-sm btn-info" id="backtoVideo" style="min-width: 90px;">Back to list</button>
                                                                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="CallSaveUpdateLessonTopicVideo()">Save</button>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="tab-pane" id="tabs-3" role="tabpanel">
                                                        <div ng-show="!CurrentLessionTopic.LessonId" style="background: linear-gradient(135deg, #e8f5e9, #ffffff);border-left: 6px solid #4caf50;
                                                            color: #1f4d2e;padding: 16px 20px;margin-top: 12px;border-radius: 14px;font-size: 15px;line-height: 1.6;display: flex;align-items: center;
                                                            gap: 14px; box-shadow: 0 6px 18px rgba(0,0,0,0.08); animation: fadeInHint 0.5s ease-in-out;">
                                                            <div style="font-size: 28px;color: #2e7d32;animation: moveLeft 1s infinite;">
                                                                👈
                                                            </div>
                                                            <div>
                                                                <div style="font-size: 17px;font-weight: 700;color: #0b5c3b;margin-bottom: 4px;">
                                                                    Action Required
                                                                </div>
                                                                <div> Please select <b>Topic</b> from the <b>left panel</b> to continue</div>
                                                            </div>
                                                        </div>

                                                        <div id="quizlist">
                                                            <div ng-show="CurrentLessionTopic.LessonId>0">
                                                                <div class="row">
                                                                    <div class="col-md-10">
                                                                        <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<spn ng-if="CurrentLessionTopic.LessonName">.</spn>{{CurrentLessionTopic.LessonName}}</b></p>
                                                                        <p class="mb-0"><b>{{CurrentLessionTopic.LessonSNo}}<span ng-if="CurrentLessionTopic.TopicSNo">.</span>{{CurrentLessionTopic.TopicSNo}} {{CurrentLessionTopic.TopicName}}</b></p>
                                                                    </div>
                                                                    <div class="col-md-2">
                                                                        <div class="float-right mb-1">
                                                                            <button class="btn btn-sm btn-success float-right" id="addquiz"><i class="fas fa-plus w-t"></i> Add Quiz</button>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class=" sales-main-table table-scroll-x-y table-scroll">
