<style>
    .date-cell {
        position: relative;
        display: inline-block;
        width: 100%;
    }

    .truncated-date {
        cursor: pointer;
        display: inline-block;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        vertical-align: middle;
        color: #37474f;
        transition: all 0.2s ease;
        border-radius: 6px;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 13px;
        font-weight: 500;
        line-height: 1.3;
    }

        .truncated-date:hover {
            background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
            border-color: #2196f3;
            color: #0d47a1;
            padding: 5px 8px;
            border: 1.5px solid #dee2e6;
            box-shadow: 0 3px 8px rgba(33, 150, 243, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.8);
            transform: translateY(-1px);
        }

    .date-tooltip {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        bottom: calc(100% + 10px);
        right: 0%;
        transform: translateX(-50%) translateY(-10px) scale(0.95);
        background: aliceblue;
        color: #1a237e;
        text-align: center;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        white-space: normal;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(33, 150, 243, 0.3);
        border: 1px solid #bbdefb;
        font-weight: 600;
        backdrop-filter: blur(10px);
        z-index: 9999;
        min-width: 400px;
    }

    .date-cell:hover .date-tooltip {
        visibility: visible;
        opacity: 1;
        /* transform: translateX(-50%) translateY(0) scale(1);*/
        transform: translateX(-10%) translateY(0) scale(1);
    }

    .date-tooltip::before {
        content: "";
        position: absolute;
        top: 100%;
        right: 12px;
        width: 0;
        height: 0;
        border-top: 10px solid aliceblue;
        border-left: 10px solid transparent;
        filter: drop-shadow(2px 3px 2px rgba(0,0,0,0.1));
    }

    .btn-action {
        background: linear-gradient(135deg, #ebf5e5, #ebf5e5);
        border: 1px solid #76be4e61;
        color: #025a58;
        font-weight: 600;
        box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        border-radius: 8px;
    }

        .btn-action i {
            margin-right: 5px;
        }

        .btn-action:hover {
            background: #76be4e;
            color: #000;
            transform: translateY(-2px);
            box-shadow: 0 5px 10px rgba(0,0,0,0.15);
        }

        .btn-action:active {
            background: #5aa33c;
            color: #fff;
            transform: translateY(0);
            box-shadow: 0 3px 6px rgba(0,0,0,0.1);
        }

        /* AngularJS "selected" class for persistent active */
        .btn-action.active-btn {
            background: #5aa33c !important; /* same as :active */
            color: #fff !important;
            transform: translateY(0);
            box-shadow: 0 3px 6px rgba(0,0,0,0.1);
        }
    /*.nav-tabs .nav-link.active, .nav-tabs .nav-item.show .nav-link {
        color: #495057 !important;
    }*/
</style>

