
<style>
    .row {
        margin-left: -5px;
        margin-right: -5px;
    }

    .col-md-4 {
        padding-left: 5px;
        padding-right: 5px;
        margin-bottom: -15px;
    }

    .report-card {
        border-radius: 12px;
        border: 1px solid #ececec;
        cursor: pointer;
        height: 80px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .payment-report-title {
        margin-top: -25px; /* adjust as needed */
    }

        .report-card:hover {
            background-color: #d4edc9; /* slightly darker on hover */
            transform: translateY(-4px);
            box-shadow: 0 6px 14px rgba(0, 0, 0, 0.08);
        }

    .report-search {
        width: 50%;
        height: 42px;
        border-radius: 25px;
        padding-left: 20px;
        font-size: 14px;
    }

    .star-btn {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        z-index: 10;
    }

    .report-card.note-style .card-body {
        display: flex;
        padding: 0;
        height: 100%;
    }

    /* Left vertical strip */
    .note-strip {
        width: 7px;
        background: #76BE4E;
        border-radius: 12px 0 0 12px;
    }

    /* Content area */
    .note-content {
        flex: 1;
        background: #E6FFE6;
        padding: 12px 18px;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Keep height aligned */
    .report-card.note-style {
        height: 80px;
        overflow: hidden;
    }


</style>

