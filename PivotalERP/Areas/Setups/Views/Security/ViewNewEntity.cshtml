@*@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")*@
<script>
    var TranId=@ViewBag.TranId;
</script>
<style>
    .fa-upload {
        background-color: #28a745;
        color: #fff;
        padding: 5px;
        font-size: 15px;
    }

    .img-preview {
        height: 150px;
        width: auto;
        border: 1px solid green;
    }

    .btn-add-file {
        padding: 35px 35px;
        border: 2px dotted green;
    }

    .fa-plus-circle {
        color: #28a745;
        font-size: 20px;
    }

    .dz-image img {
        width: 130px;
        height: 130px;
    }

    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<link rel="stylesheet" href="~/wwwroot/dynamic-erp/css/dropzone.css" />
<script>
      var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.NewEntity)";
</script>
<script src="~/jslib/setup/ViewNewEntity.js?v=1"></script>
<div ng-app="myApp" ng-controller="viewNewEntityCtrl" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllData()" ng-cloak>
    <div class="container-fluid">
        <section class="iframe-content-starts-here" style="padding-top:50px!important">
            <div class="tab-content">
                <div class="card-primary card-tabs">
                    <div class="card-header with-gradient-bg p-0 border-bottom-0">
                        <div class="card-header p-0 border-bottom-0">
                            <ul class="nav nav-tabs pt-1" id="custom-tabs-four-tab" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">{{NewEntity.LabelName}}</a>
                                </li>
                            </ul>
                        </div>
                        </div>
                        <div class="card-body p-2" >
                            <div class="tab-content" id="custom-tabs-four-tabContent">
                                <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                    <header class="row">
                                        <div class="col-md-8">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Show</span>
                                                        </div>
                                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="paginationOptions.pageSize">
                                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==paginationOptions.pageSize">{{pp.text}}</option>
                                                        </select>
                                                        <div class="input-group-append">
                                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <div class="input-group-prepend">
                                                            <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                                <option ng-value="asp" ng-repeat="asp in SearchOptions" ng-selected="asp.text==paginationOptions.SearchColDet.text">{{asp.text}}</option>
                                                            </select>
                                                        </div>
                                                        <input class="form-control form-control-navbar" type="search"
                                                               placeholder="Search" aria-label="Search" ng-model="paginationOptions.SearchVal" ng-change="ReSearchData(-1)">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <!-- end col-md-8 -->
                                        <div class="col-md-4 text-right">
                                            <div class="dropdown dnld-file" title="Download File">
                                                <a class="btn btn-secondary btn-light btn-sm wait"
                                                   title="Refresh" ng-click="ReSearchData(-1)">
                                                    <i class="fas fa-sync-alt"></i>
                                                </a>
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                        id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right"
                                                     aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>

                                                    <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="NewEntity.Name" report-name="ReportTile" ignore-column="'-1'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="NewEntity.Name" report-name="ReportTile" ignore-column="'-1'" file-type="'csv'"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>

                                                    <div ng-repeat="imc in ImageFieldsColl">
                                                        <label for="import-filetoupload{{$index}}" class="dropdown-item wait" title="Upload Files"><i class="fas fa-upload text-success mr-3" style="font-size:20px"></i>{{imc.Label}}</label>
                                                        <input id="import-filetoupload{{$index}}" type="file" multiple class="form-control form-control-sm" style="display: none;" file-model ng-model="imc.Files_TMP" after-selected="UploadFiles(imc)">
                                                    </div>

                                                </div>
                                                <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                                   title="Print">
                                                    <i class="fas fa-print"></i>
                                                </a>


                                            </div>


                                        </div>
                                    </header>
                                    <div class="search-toolbar mt-2">

                                        <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th ng-click="sort('Id')" style="text-align: center; width: 5%;">
                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Id'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Name')" style="text-align:left" ng-repeat="fc in NewEntity.FilterFieldColl">
                                                        {{fc.Label}}
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='{{fc.F_Name}}'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th class="noprint" style="text-align:center;width: 10%;">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                                    <td style="text-align:center;margin:auto">
                                                        {{($index+1)}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left;" ng-repeat-start="fc in NewEntity.FilterFieldColl" ng-class="{{(fc.FieldType==2 || fc.FieldType==5  || fc.FieldType==12) ? '' :'noprint' }}" ng-hide="fc.FieldType==2 || fc.FieldType==5  || fc.FieldType==12">
                                                        {{sd[fc.F_Name]}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left;" ng-class="{{fc.FieldType==5 ? '' :'noprint' }}" ng-show="fc.FieldType==5">
                                                        {{sd[fc.F_Name] |number:2}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left;" ng-class="{{fc.FieldType==12 ? '' :'noprint' }}" ng-show="fc.FieldType==12">
                                                        <div class="card-body" ng-bind-html="sd[fc.F_Name] | unsafe" ng-show="fc.FieldType==12">
                                                        </div>
                                                    </td>
                                                    <td style="margin:auto;text-align:left;" ng-repeat-end ng-class="{{fc.FieldType==2 ? '' :'noprint' }}" ng-show="fc.FieldType==2">
                                                        {{sd[fc.F_Name] |dateFormat}}
                                                    </td>
                                                    <td class="project-actions text-center noprint">
                                                        <div class="btn-group-sm">
                                                            <a class="p-1" href="#" ng-click="ShowDocument(sd)" ng-show="NewEntity.HasDocument==true">
                                                                <i class="fas fa-eye text-secondary"></i>
                                                            </a>
                                                            <a href="#" class="btn btn-sm  btn-info" ng-click="GetRecordById(sd)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-sm btn-danger" ng-click="DeleteRecordById(sd,$index)"><i class="fas fa-trash"></i></a>
                                                            <a href="#" class="btn btn-sm btn-primary" ng-click="PrintVoucher(sd,$index)" ng-show="NewEntity.TemplateColl.length>0"><i class="fas fa-print"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                                     on-page-change="ReSearchData(newPageNumber)">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                    <div class="">
                                        <form>
                                            <div class="row">
                                                <div class="col-sm-{{udf.ColWidth}}" ng-repeat="udf in NewEntity.FieldColl" ng-if="udf.FieldType!=14">
                                                    <div class="form-group">
                                                        <label for="id{{udf.Name}}">{{udf.Label}}<span style="color:red" ng-show="udf.IsMandatory==true">*</span></label>
                                                        <udf-entity udf="udf" be-data="beData" change-event="ChangeProperties(udf.Name)" click-event="ClickEvent(udf.Name)" new-entity="NewEntity"></udf-entity>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row" ng-repeat="udf in NewEntity.DropZoneColl">
                                                <div class="card-body mt-0" id="add-file-area" style="background-color: #eff0ef;">
                                                    <label><b>Upload Photos</b></label>
                                                    <div id="actions" class="row">
                                                        <div class="col-md-1 mt-4">
                                                            <div class="btn-group">
                                                                <span class="btn-add-file col fileinput-button">
                                                                    <span><i class="fas fa-plus-circle"></i></span>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-11">
                                                            <div class="d-flex p-2" id="previews" style="overflow-x: auto;">
                                                                <div id="template">
                                                                    <a data-dz-remove class="cancel float-right">
                                                                        <i class="fas fa-times-circle" style="  color:#28a745;font-size: 14px;"></i>
                                                                    </a>
                                                                    <span class="preview p-2 ml-2"><img style="height:150px;width:auto" src="data:," alt="" data-dz-thumbnail /></span>
                                                                    <div class="align-items-center" style="width: 100%;">
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row" ng-show="NewEntity.ChieldEntities.length>0" ng-repeat="chEntity in NewEntity.ChieldEntities">
                                                <div class="table-scroll-x-y mb-1 table-container">
                                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                        <thead class="text-center">
                                                            <tr>
                                                                <th style="width: 50px; background-color: #ececec !important">S.No.</th>
                                                                <th style="width: {{(chUDF.ColWidth*100)}}px;" ng-repeat="chUDF in chEntity.FieldColl">{{chUDF.Label}}</th>
                                                                <th class="text-center align-middle" style="width: 70px; background-color: #ececec !important">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="ledAllocation in chEntity.RowsDataColl">
                                                                <td align="center">{{$index+1}}</td>
                                                                <td ng-repeat="chUdf in ledAllocation.FieldColl">
                                                                    <udf-entity udf="chUdf" be-data="ledAllocation" change-event="ChangeProperties(chUdf.Name)" click-event="ClickEvent(chUdf.Name)" new-entity="NewEntity"></udf-entity>
                                                                </td>
                                                                <td class="text-center">
                                                                    <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddChieldRow(chEntity.RowsDataColl,$index)">
                                                                        <i class="fas fa-plus text-info"></i>
                                                                    </a>
                                                                    <a class="p-1" href="#" data-original-title="Delete Row." ng-click="delAddChieldRow(chEntity.RowsDataColl,$index)">
                                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                                    </a>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </form>

                                    </div>
                                    <footer class="text-center mt-4">
                                        <div class="control-btns">
                                            <button type="button" class="btn btn-sm btn-default" style="min-width:80px" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Reset</button>
                                            <button type="button" class="btn btn-sm btn-success"  style="min-width:80px" ng-click="AddNewData()"><span class="glyphicon glyphicon-save"></span>Save</button>
                                        </div>
                                    </footer>
                                </div>
                            </div>

                        </div>
                        <!-- /.card -->
                   


                    <!-- /.card -->
                </div>
                <!-- /.container-fluid -->
            </div>
</section>
    </div>


    <div class="modal fade" id="modal-showDocument">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Document List</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="table-responsive">
                            <table class="table table-hover border">
                                <thead>
                                    <tr>
                                        <th scope="col" style="width: 20px">SN.</th>
                                        <th scope="col" style="width:150px">Name</th>
                                        <th scope="col" style="width: 130px">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="dcc in SelectedTran.DocumentColl">
                                        <th scope="row">{{$index+1}}</th>
                                        <td>{{dcc.Name}}</td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{dcc.DocPath}}" class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc." download="{{dcc.Name}}"><i class="fas fa-download"></i></a>
                                                <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc" ng-click="ShowPersonalImg(dcc)"><i class="fas fa-eye"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Close</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>


</div>

<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>
<script src="~/wwwroot/dynamic-erp/js/dropzone.js"></script>
 